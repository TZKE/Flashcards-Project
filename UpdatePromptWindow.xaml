<Window x:Class="AIFlashcardMaker.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OrbitLab Update Available"
        Width="560" Height="460" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ShowInTaskbar="False">
    <!-- Phase 10 OPTIONAL-update prompt (forced=false). Unlike UpdateRequiredWindow,
         "Later" (or closing) continues into the app normally — nothing is blocked.
         "Install Update" drives the existing secure updater (Velopack feed over HTTPS;
         browser download of the official installer as the fallback). -->
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                <TextBlock Text="⬆" FontSize="22" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="OrbitLab Update Available" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="MessageText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="What's new" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" FontSize="12.5"
                               Foreground="{StaticResource TextBrush}" Text="—"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="12.5"
                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterButton" Content="Later" Style="{StaticResource SoftButton}"
                        Height="42" MinWidth="110" Click="Later_Click"/>
                <Button x:Name="InstallButton" Content="Install Update" Style="{StaticResource PremiumButton}"
                        Height="42" MinWidth="160" Margin="10,0,0,0" Click="Install_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

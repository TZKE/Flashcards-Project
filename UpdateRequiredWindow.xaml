<Window x:Class="AIFlashcardMaker.UpdateRequiredWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Required update"
        Width="640" Height="600" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ShowInTaskbar="True">
    <!-- Phase 6A forced-update gate. Shown ONLY when the backend was reachable and
         explicitly returned forced=true with this version below the minimum supported
         version. Closing this window closes the app: there is no path into the app
         from here except updating. -->
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                <TextBlock Text="⬆" FontSize="22" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="HeaderText" Text="Required update available" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="VersionText" FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="ExplainText" TextWrapping="Wrap" FontSize="13"
                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"
                   Text="This version of OrbitLab is no longer supported. Please update to continue — your research projects stay on this device and are not affected by updating."/>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="What's new" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" FontSize="12.5"
                               Foreground="{StaticResource TextBrush}" Text="—"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="12.5"
                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="DownloadButton" Content="Download and Update" Style="{StaticResource PremiumButton}"
                        Height="44" MinWidth="190" Click="Download_Click"/>
                <Button x:Name="OpenInstallerButton" Content="Open installer" Style="{StaticResource PremiumButton}"
                        Height="44" MinWidth="150" Margin="10,0,0,0" Visibility="Collapsed" Click="OpenInstaller_Click"/>
                <Button x:Name="OpenFolderButton" Content="Open download folder" Style="{StaticResource SoftButton}"
                        Height="44" MinWidth="170" Margin="10,0,0,0" Visibility="Collapsed" Click="OpenFolder_Click"/>
                <Button Content="Join Telegram Channel" Style="{StaticResource SoftButton}"
                        Height="44" MinWidth="180" Margin="10,0,0,0" Click="JoinTelegram_Click"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <TextBlock x:Name="SupportText" FontSize="12" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
            <Button Content="Close OrbitLab" Style="{StaticResource SoftButton}" Height="38" MinWidth="130"
                    HorizontalAlignment="Right" Click="CloseApp_Click"/>
        </Grid>
    </Grid>
</Window>

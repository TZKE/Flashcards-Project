        <StreamGeometry x:Key="IconResearch">M8 3 H16 V4.7 H14.6 V9.1 L20 19.2 A1.7 1.7 0 0 1 18.5 21.7 H5.5 A1.7 1.7 0 0 1 4 19.2 L9.4 9.1 V4.7 H8 Z</StreamGeometry>

    </Application.Resources>
</Application>

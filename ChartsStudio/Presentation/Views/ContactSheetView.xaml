<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.ContactSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 2 — Contact Sheet.

        Cards carry their title, reason and cautions as TEXT, which appears immediately. Only
        the thumbnail arrives asynchronously. That ordering is what makes the sheet readable
        before a single figure has been drawn.

        All styles are declared locally: the module stays self-contained and App.xaml is left
        alone (this codebase has a documented stale-XAML gotcha after App.xaml edits).
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Kept is the core gesture of this surface, so it must be legible at a glance across
             the whole sheet — not just a changed button label. A kept card takes the primary
             border and a badge, so scanning answers "which did I keep?" without reading. -->
        <Style x:Key="FigureCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Width" Value="360"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsKept}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Keep button, filled once kept so the action reads as done rather than available. -->
        <Style x:Key="KeepButton" TargetType="Button" BasedOn="{StaticResource CardActionButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsKept}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Sheet header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Proposed figures"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Text="{Binding KeptSummary}"
                           FontSize="12.5"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"/>

                <TextBlock Text="drawing…"
                           FontSize="12"
                           Foreground="{StaticResource SoftMutedBrush}"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <Button Content="Add a figure"
                    Style="{StaticResource CardActionButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="AddFigure_Click"/>
        </Grid>

        <!-- Cards.
             Bottom padding so the last row clears the scroll edge instead of being sliced. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel Margin="0,0,0,10">

                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FigureCardBorder}">
                                <StackPanel>

                                    <!-- Figure area: fixed height so cards do not jump as
                                         thumbnails arrive.

                                         Background is WHITE, not the soft card tint. The
                                         rendered PNG has a white figure background, and a
                                         tinted container left a visible hard-edged rectangle
                                         inside the rounded corner. Matching the two removes
                                         the seam. The 16:9 area matches the render aspect so
                                         the figure fills it instead of letterboxing. -->
                                    <Border Height="204"
                                            CornerRadius="14,14,0,0"
                                            Background="White"
                                            ClipToBounds="True">
                                        <Grid>
                                            <!-- Drawn -->
                                            <Image Source="{Binding Image}"
                                                   Stretch="Uniform"
                                                   Margin="6,8,6,4"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding IsRendered, Converter={StaticResource BoolToVis}}"/>

                                            <!-- Drawing -->
                                            <TextBlock Text="drawing…"
                                                       FontSize="12"
                                                       Foreground="{StaticResource SoftMutedBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                                            <!-- Failed: explains itself, never a blank frame -->
                                            <TextBlock Text="{Binding FailureReason}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="280"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Text -->
                                    <StackPanel Margin="18,14,18,0">
                                        <!-- Kept badge — the at-a-glance marker -->
                                        <Border Background="{StaticResource PrimarySoftBrush}"
                                                CornerRadius="5"
                                                Padding="7,2"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,8"
                                                Visibility="{Binding IsKept, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="KEPT"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="9.5"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Text="{Binding Headline}"
                                                   FontSize="14.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="{Binding Subtitle}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SoftMutedBrush}"
                                                   Margin="0,3,0,0"/>

                                        <TextBlock Text="{Binding Rationale}"
                                                   FontSize="12.5"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0"/>

                                        <!-- Cautions travel WITH the card, so small n is seen
                                             before the user invests in the figure. -->
                                        <Border Background="{StaticResource WarningSoftBrush}"
                                                CornerRadius="7"
                                                Padding="9,5"
                                                Margin="0,10,0,0"
                                                Visibility="{Binding HasCautions, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding CautionText}"
                                                       FontSize="11.5"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Orientation="Horizontal" Margin="18,14,18,18">
                                        <Button Content="{Binding KeepLabel}"
                                                Style="{StaticResource KeepButton}"
                                                Click="Keep_Click"
                                                Margin="0,0,8,0"/>
                                        <Button Content="Remove"
                                                Style="{StaticResource CardActionButton}"
                                                Click="Remove_Click"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state: always says WHY, and what to do next -->
                <Border Padding="32"
                        MaxWidth="620"
                        HorizontalAlignment="Left"
                        Background="{StaticResource SoftCardBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="No figures to propose yet"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding EmptyReason}"
                                   FontSize="13.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="21"
                                   Margin="0,10,0,0"/>

                        <!-- Says what Charts Studio WILL do, so an empty sheet reads as "not
                             yet" rather than "nothing here". -->
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,13"
                                Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="What happens once they're available"
                                           FontSize="11.5"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource SoftMutedBrush}"/>
                                <TextBlock FontSize="12.5"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="20"
                                           Margin="0,7,0,0"
                                           Text="Charts Studio proposes figures built from your own variables — you keep the ones you want. Every value comes from the statistics OrbitLab already computed, never from a fresh calculation."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

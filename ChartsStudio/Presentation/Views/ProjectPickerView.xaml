<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.ProjectPickerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 1 — Project Picker.

        Every style used here is declared LOCALLY rather than added to App.xaml. Two reasons:
        the module stays self-contained, and App.xaml is left untouched — this codebase has a
        documented gotcha where incremental builds serve stale XAML after App.xaml edits, and
        there is no reason for a new module to walk into it.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Card-shaped button: full-bleed content, no default chrome, hover lift. -->
        <Style x:Key="ProjectCardButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Top"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardMetaText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Heading -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Charts Studio" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Select a research project to begin."
                       FontSize="14"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,20,0,14"
              Visibility="{Binding HasAnyProjects, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="420"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Style="{StaticResource EditorTextBox}"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Search by project name, specialty or study type"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding CountSummary}"
                       Style="{StaticResource CardMetaText}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Grid>

        <!-- Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
            <StackPanel>

                <ItemsControl ItemsSource="{Binding VisibleProjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource ProjectCardButton}"
                                    Width="320"
                                    Margin="0,0,16,16"
                                    Click="ProjectCard_Click">
                                <StackPanel>

                                    <!-- Title row + last-opened badge -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TitleDisplay}"
                                                   FontSize="15.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="44"/>

                                        <Border Grid.Column="1"
                                                Background="{StaticResource PrimarySoftBrush}"
                                                CornerRadius="6"
                                                Padding="7,2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding IsLastOpened, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Last opened"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       FontSize="10"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding ContextDisplay}"
                                               Style="{StaticResource CardMetaText}"
                                               Margin="0,6,0,0"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Separator Margin="0,14,0,12" Opacity="0.35"/>

                                    <!-- Facts -->
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding VariableDisplay}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Extraction Sheet"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SoftMutedBrush}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding ParticipantDisplay}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Dataset"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SoftMutedBrush}"/>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="{Binding FigureDisplay}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Charts Studio"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SoftMutedBrush}"/>
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="{Binding UpdatedDisplay}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Last modified"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SoftMutedBrush}"/>
                                        </StackPanel>
                                    </UniformGrid>

                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty: no projects at all -->
                <Border Padding="36"
                        MaxWidth="560"
                        HorizontalAlignment="Left"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasAnyProjects}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="No research projects yet"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Charts Studio builds figures from a research project's variables and analyses. Create a project in Research Lab and import your data, then come back here."
                                   FontSize="13.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Empty: search matched nothing -->
                <Border Style="{StaticResource CardBorder}"
                        Padding="28"
                        MaxWidth="560"
                        HorizontalAlignment="Left"
                        Visibility="{Binding HasNoMatches, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="No projects match your search"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Try a different project name, specialty or study type."
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>

<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.ExportDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 5 — Export dialog.

        A skin over ExportDialogViewModel, which is a skin over the headless ExportService. No
        export logic here: the view gathers choices and shows progress. Profiles, formats and
        naming are all bound; the destination has a Browse button backed by the injected
        folder picker.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ExLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SoftMutedBrush}"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>

        <Style x:Key="ExAction" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#77000000" Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                CornerRadius="16" Width="600" MaxHeight="720"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Margin="26,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Export figures" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding ScopeSummary}" FontSize="12.5"
                               Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Options — disabled while an export runs, so choices can't change mid-run -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExporting}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="PROFILE" Style="{StaticResource ExLabel}" Margin="0,4,0,6"/>
                        <ComboBox Height="36" VerticalContentAlignment="Center" FontSize="12.5"
                                  ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="DisplayName"/>
                        <TextBlock Text="{Binding ProfileSummary}" FontSize="11.5"
                                   Foreground="{StaticResource SoftMutedBrush}" Margin="2,6,0,0"/>

                        <TextBlock Text="FORMATS" Style="{StaticResource ExLabel}"/>
                        <ItemsControl ItemsSource="{Binding Formats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3">
                                        <StackPanel Margin="4,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12.5"
                                                       FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap" MaxWidth="480"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="FILE NAMES" Style="{StaticResource ExLabel}"/>
                        <ComboBox Height="36" VerticalContentAlignment="Center" FontSize="12.5"
                                  ItemsSource="{Binding NameTemplates}" SelectedItem="{Binding SelectedNameTemplate}"
                                  DisplayMemberPath="Name"/>

                        <TextBlock Text="DESTINATION" Style="{StaticResource ExLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Height="36" VerticalContentAlignment="Center"
                                     Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource ExAction}"
                                    Margin="8,0,0,0" Click="Browse_Click"/>
                        </Grid>

                        <TextBlock Text="PACKAGE" Style="{StaticResource ExLabel}"/>
                        <CheckBox Content="Organise as a package (figures/, captions/, manifest.json)"
                                  IsChecked="{Binding AsPackage}" FontSize="12.5"
                                  Foreground="{StaticResource MutedBrush}" Margin="0,2"/>
                        <CheckBox Content="Include figure captions (TXT + Markdown)"
                                  IsChecked="{Binding IncludeCaptions}" IsEnabled="{Binding AsPackage}"
                                  FontSize="12.5" Foreground="{StaticResource MutedBrush}" Margin="20,2,0,2"/>
                        <CheckBox Content="Include reproducibility manifest"
                                  IsChecked="{Binding IncludeManifest}" IsEnabled="{Binding AsPackage}"
                                  FontSize="12.5" Foreground="{StaticResource MutedBrush}" Margin="20,2,0,2"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: progress + actions -->
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <StackPanel Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Height="8" Minimum="0" Maximum="1" Value="{Binding ProgressFraction, Mode=OneWay}"/>
                        <TextBlock Text="{Binding ProgressLabel}" FontSize="11.5"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="8" Padding="12,9"
                            Margin="0,0,0,8"
                            Visibility="{Binding ShowResult, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource ExAction}" Margin="0,0,8,0"
                                Click="Cancel_Click"
                                Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Close" Margin="0,0,8,0" Click="Close_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SoftButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExporting}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Export" MinWidth="96"
                                Click="Export_Click" IsEnabled="{Binding CanExport}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExporting}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.StudioShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 1 — studio shell.

        LAYOUT ONLY. The three surfaces are placeholders and navigation between them is not
        wired; that is Phase 2 and beyond.

        What IS real here is the context header. It is the first beat of the studio's opening
        sequence — the moment that proves the project was understood before anything is
        proposed — so it reads from the live AnalysisContext rather than from placeholder text.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Placeholder region: dashed outline, so it never reads as finished UI. -->
        <Style x:Key="PlaceholderRegion" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="PlaceholderTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="PlaceholderBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
        </Style>

        <Style x:Key="PhaseTag" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============================ CONTEXT HEADER ============================ -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding ProjectTitle}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding ContextSummary}"
                               FontSize="13.5"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding VariableBreakdown}"
                               FontSize="12.5"
                               Foreground="{StaticResource SoftMutedBrush}"
                               Margin="0,4,0,0"
                               Visibility="{Binding HasVariableBreakdown, Converter={StaticResource BoolToVis}}"/>

                    <!-- Readiness -->
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Border CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsReady}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ReadinessDisplay}" FontSize="11" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <TextBlock Text="{Binding ReadinessReasons}"
                                   FontSize="12"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="620"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding HasReadinessReasons, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Button Content="Change project"
                            Style="{StaticResource SoftButton}"
                            Click="ChangeProject_Click"/>

                    <TextBlock FontSize="10.5"
                               Foreground="{StaticResource SoftMutedBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,10,0,0"
                               ToolTip="Content fingerprint of the analysis this session was built from. Figures record it so they can detect when your data has changed.">
                        <Run Text="context"/>
                        <Run Text="{Binding FingerprintDisplay, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Text="{Binding CapturedAtDisplay}"
                               FontSize="10.5"
                               Foreground="{StaticResource SoftMutedBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================ THREE SURFACES ============================ -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Contact Sheet -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PlaceholderRegion}" Margin="0,0,16,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="460">
                    <TextBlock Text="Contact Sheet" Style="{StaticResource PlaceholderTitle}" HorizontalAlignment="Center"/>
                    <TextBlock Style="{StaticResource PlaceholderBody}"
                               TextAlignment="Center"
                               Text="Proposed figures for this project will develop here — real figures built from your own variables, ready to keep or cut."/>
                    <Border Style="{StaticResource PhaseTag}" HorizontalAlignment="Center">
                        <TextBlock Text="Phase 2" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Figure Shelf -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PlaceholderRegion}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Figure Shelf" Style="{StaticResource PlaceholderTitle}"/>
                    <TextBlock Style="{StaticResource PlaceholderBody}"
                               Text="Figures you keep become a numbered set here, ordered and checked for consistency across the whole paper."/>
                    <Border Style="{StaticResource PhaseTag}">
                        <TextBlock Text="Phase 4" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Figure Canvas -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Style="{StaticResource PlaceholderRegion}"
                    Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Figure Canvas" Style="{StaticResource PlaceholderTitle}"/>
                    <TextBlock Style="{StaticResource PlaceholderBody}"
                               Text="Opening a figure expands it here for editing — variables, scales, labels and style — with its provenance receipt and caption beneath."/>
                    <Border Style="{StaticResource PhaseTag}">
                        <TextBlock Text="Phase 3" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>

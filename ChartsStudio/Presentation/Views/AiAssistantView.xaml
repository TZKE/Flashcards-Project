<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.AiAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 6 — AI Advisory Assistant ("Publication assistant").

        A side panel over the studio. Every rule lives in the view model / service; this view
        gathers clicks and shows advisory items. The review actions are always enabled (they run
        offline); AI adds suggestions when available. A caption draft is shown for the user to
        apply — never applied automatically.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="AiAction" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Scrim + right-docked panel -->
    <Grid x:Name="Root" Background="#55000000" Focusable="True"
          IsVisibleChanged="Root_IsVisibleChanged" PreviewKeyDown="Root_PreviewKeyDown"
          Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1,0,0,0"
                Width="420" HorizontalAlignment="Right">
            <Grid Margin="22,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <StackPanel>
                        <TextBlock Text="{Binding HeaderText}" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding AvailabilityNote}" FontSize="11.5"
                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Content="Close" Style="{StaticResource SoftButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Click="Close_Click"/>
                </Grid>

                <!-- Per-figure actions (editor context) -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0"
                            Visibility="{Binding IsFigureContext, Converter={StaticResource BoolToVis}}">
                    <Button Style="{StaticResource AiAction}" Click="Caption_Click">
                        <StackPanel>
                            <TextBlock Text="Draft a caption" FontWeight="SemiBold"/>
                            <TextBlock Text="A publication caption using this figure's exact numbers."
                                       FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AiAction}" Click="Critique_Click">
                        <StackPanel>
                            <TextBlock Text="Critique this figure" FontWeight="SemiBold"/>
                            <TextBlock Text="Suggestions to improve how it is presented."
                                       FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AiAction}" Click="Accessibility_Click">
                        <StackPanel>
                            <TextBlock Text="Accessibility review" FontWeight="SemiBold"/>
                            <TextBlock Text="Colourblind-safety, contrast and print legibility."
                                       FontSize="11" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Busy / caption draft -->
                <StackPanel Grid.Row="2" Margin="0,4,0,0">
                    <TextBlock Text="Working…" FontSize="12" Foreground="{StaticResource SoftMutedBrush}"
                               Margin="0,4,0,8" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                    <!-- Caption draft: editable, applied only on the user's press -->
                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="10" Padding="12"
                            Margin="0,4,0,4"
                            Visibility="{Binding HasCaptionDraft, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Caption draft" FontSize="11.5" FontWeight="Bold"
                                       Foreground="{StaticResource SoftMutedBrush}"/>
                            <TextBox Text="{Binding CaptionDraft, Mode=OneWay}" IsReadOnly="True"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60"
                                     Background="Transparent" BorderThickness="0" FontSize="13"
                                     Foreground="{StaticResource TextBrush}" Margin="0,6,0,8"/>
                            <Button Content="Use as caption" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Click="ApplyCaption_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Collapse when empty via a trigger. A string cannot go through
                         BooleanToVisibilityConverter (the cast throws and WPF falls back to
                         Visible), which used to leave an empty line showing. -->
                    <TextBlock Text="{Binding StatusNote}" FontSize="11.5"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusNote}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Advisory items -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="10"
                                        Padding="12,10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="18" Height="18" CornerRadius="9" Margin="0,0,8,0"
                                                    VerticalAlignment="Top">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource PrimarySoftBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding SeverityGlyph}" FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SourceLabel}" FontSize="10"
                                                           Foreground="{StaticResource SoftMutedBrush}" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Detail}" FontSize="12"
                                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                                                   Margin="26,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

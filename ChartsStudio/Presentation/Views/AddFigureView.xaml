<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.AddFigureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AIFlashcardMaker"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 2 — Add Figure.

        Organised BY VARIABLE, not by chart type. A researcher thinks "I need a figure for my
        primary outcome", not "I need a box plot" — so the variable leads and the form is
        supporting detail, the same inversion the contact sheet cards use.

        Only figures that can honestly be drawn appear here.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="OptionRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SoftCardBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Scrim + panel -->
    <Grid x:Name="Root" Background="#66000000" Focusable="True"
          IsVisibleChanged="Root_IsVisibleChanged" PreviewKeyDown="Root_PreviewKeyDown"
          Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="16"
                Width="560"
                MaxHeight="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="22,20,22,0">
                    <StackPanel>
                        <TextBlock Text="Add a figure"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Every figure your project's results can support, by variable."
                                   FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Content="Close"
                            Style="{StaticResource SoftButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Click="Close_Click"/>
                </Grid>

                <!-- Default TextBox style, not EditorTextBox: the latter is for multi-line
                     notes and sets MinHeight=120, which would dominate a dialog this size. -->
                <TextBox Grid.Row="1"
                         Margin="22,16,22,12"
                         local:Watermark.Text="Search figures…"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search by variable or chart type"/>

                <!-- Options -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Options}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource OptionRowButton}" Click="Option_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Headline}"
                                                           FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ChartTypeName}"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource SoftMutedBrush}"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding BestFor}"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StatusLabel}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource SoftMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding EmptyReason}"
                                   FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="22,18,22,18">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasOptions}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="AIFlashcardMaker.ChartsStudio.Presentation.Views.ChartsStudioHostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AIFlashcardMaker.ChartsStudio.Presentation.Views"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!--
        Charts Studio Phase 1 — module host.

        The single surface MainWindow embeds. It owns nothing but which child is showing;
        all state lives in ChartsStudioViewModel. Keeping the host this thin is what keeps
        the module's footprint inside MainWindow down to one control.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

        <!-- Project picker -->
        <views:ProjectPickerView DataContext="{Binding Picker}"
                                 Visibility="{Binding DataContext.IsPickerVisible,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Converter={StaticResource BoolToVis}}"/>

        <!-- Open project -->
        <views:StudioShellView DataContext="{Binding Shell}"
                               Visibility="{Binding DataContext.IsShellVisible,
                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                            Converter={StaticResource BoolToVis}}"/>

        <!-- Preparing -->
        <Grid Visibility="{Binding IsLoadingVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Preparing project…"
                           FontSize="15"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Load failure -->
        <Grid Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource CardBorder}"
                    Padding="32"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="This project could not be opened"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="13"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                    <Button x:Name="ErrorBackButton"
                            Content="Choose another project"
                            Style="{StaticResource SoftButton}"
                            HorizontalAlignment="Left"
                            Margin="0,18,0,0"
                            Click="ChangeProject_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>

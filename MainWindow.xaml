<Window x:Class="AIFlashcardMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIFlashcardMaker"
        Title="AI Flashcard Maker"
        Icon="Assets/appicon.ico"
        Width="1280"
        Height="820"
        MinWidth="1000"
        MinHeight="620"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Grid Background="{StaticResource AppBgBrush}">

        <!-- AUTH SCREEN -->
        <Grid x:Name="AuthGrid" Margin="34">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.46*" MinWidth="360"/>
                <ColumnDefinition Width="0.54*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT HERO -->
            <StackPanel Grid.Column="0" Margin="28,26,28,18" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="56" Height="56" Background="{StaticResource PrimaryBrush}" CornerRadius="16" Margin="0,0,14,0">
                        <Path Data="{StaticResource IconBolt}" Fill="White" Width="27" Height="27" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="AI Flashcard Maker" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Premium medical study workspace" FontSize="13" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="Generate, organize, and study high-yield flashcards."
                           FontSize="29"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap"
                           LineHeight="37"
                           Margin="0,0,34,12"/>

                <TextBlock Text="A clean Windows desktop app for medical students: decks, Z.ai generation, spaced repetition, export, and animated study feedback."
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"
                           LineHeight="21"
                           Margin="0,0,54,16"/>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,54,14" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="15" Width="58" Height="58">
                            <Path Data="{StaticResource IconStudy}"
                                  Fill="{StaticResource PrimaryBrush}"
                                  Width="30"
                                  Height="30"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Study smarter, not harder" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Create decks, review weak cards, and export to Anki when needed."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <UniformGrid Columns="2" Margin="0,0,54,0">
                    <Border Style="{StaticResource SoftCardBorder}" Margin="0,0,10,10">
                        <StackPanel>
                            <Border Background="{StaticResource PrimarySoftBrush}" Width="40" Height="40" CornerRadius="11" HorizontalAlignment="Left">
                                <Path Data="{StaticResource IconDecks}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Multi-deck" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="Organize topics cleanly." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardBorder}" Margin="0,0,0,10">
                        <StackPanel>
                            <Border Background="{StaticResource PrimarySoftBrush}" Width="40" Height="40" CornerRadius="11" HorizontalAlignment="Left">
                                <Path Data="{StaticResource IconGenerate}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Z.ai Cards" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="Generate from notes." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardBorder}" Margin="0,0,10,0">
                        <StackPanel>
                            <Border Background="{StaticResource WarningSoftBrush}" Width="40" Height="40" CornerRadius="11" HorizontalAlignment="Left">
                                <Path Data="{StaticResource IconFire}" Fill="{StaticResource WarningBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Streaks" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="Track daily progress." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SoftCardBorder}">
                        <StackPanel>
                            <Border Background="{StaticResource PrimarySoftBrush}" Width="40" Height="40" CornerRadius="11" HorizontalAlignment="Left">
                                <Path Data="{StaticResource IconExport}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Export" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,10,0,2"/>
                            <TextBlock Text="Copy or save for Anki." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

            </StackPanel>

            <!-- AUTH CARD -->
            <Border x:Name="AuthCard"
                    Grid.Column="1"
                    Style="{StaticResource CardBorder}"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="34">

                <TabControl x:Name="AuthTabs" Margin="0,14,0,0">
                    <TabItem Header="Login">
                        <StackPanel Margin="10,14,10,10">

                            <StackPanel HorizontalAlignment="Center" Margin="0,8,0,28">
                                <Border Width="68" Height="68" Background="{StaticResource PrimarySoftBrush}" CornerRadius="20" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconBolt}" Fill="{StaticResource PrimaryBrush}" Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Welcome back"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,4"/>

                                <TextBlock Text="Sign in to continue your flashcard workspace."
                                           FontSize="14"
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Email" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <TextBox x:Name="LoginEmailBox"
                                     Height="48"
                                     FontSize="15"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,18"
                                     KeyDown="LoginField_KeyDown"
                                     local:Watermark.Text="you@email.com"/>

                            <TextBlock Text="Password" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <PasswordBox x:Name="LoginPasswordBox"
                                         Height="48"
                                         FontSize="15"
                                         Padding="15,0"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,0,24"
                                         KeyDown="LoginField_KeyDown"/>

                            <Button Content="Login"
                                    Style="{StaticResource PremiumButton}"
                                    Click="Login_Click"
                                    Height="48"
                                    FontSize="15"
                                    Margin="0"/>

                            <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Padding="16" Margin="0,24,0,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="NeedAccess_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconKey}" Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold">
                                        <Run Text="Need access?"/>
                                        <Run Text="Create an account" FontWeight="Bold" TextDecorations="Underline"/>
                                        <Run Text="with your activation code."/>
                                    </TextBlock>
                                    <Path Grid.Column="2" Data="M 0 0 L 6 6 L 0 12" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" Margin="10,0,2,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Create Account">
                        <StackPanel Margin="10,14,10,10">

                            <StackPanel HorizontalAlignment="Center" Margin="0,4,0,24">
                                <Border Width="68" Height="68" Background="{StaticResource SuccessSoftBrush}" CornerRadius="20" HorizontalAlignment="Center">
                                    <Path Data="{StaticResource IconAccount}"
                                          Fill="{StaticResource SuccessBrush}"
                                          Width="34"
                                          Height="34"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Create account"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,14,0,4"/>

                                <TextBlock Text="Use a local demo code to unlock the app."
                                           FontSize="14"
                                           Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Email" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <TextBox x:Name="SignupEmailBox"
                                     Height="48"
                                     FontSize="15"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,14"
                                     KeyDown="SignupField_KeyDown"
                                     local:Watermark.Text="you@email.com"/>

                            <TextBlock Text="Password" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <PasswordBox x:Name="SignupPasswordBox"
                                         Height="48"
                                         FontSize="15"
                                         Padding="15,0"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,0,14"
                                         KeyDown="SignupField_KeyDown"/>

                            <TextBlock Text="Activation Code" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                            <TextBox x:Name="SignupCodeBox"
                                     Height="48"
                                     FontSize="15"
                                     Padding="15,0"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,20"
                                     KeyDown="SignupField_KeyDown"
                                     local:Watermark.Text="FLASH-MONTH-2026"/>

                            <Button Content="Create Account"
                                    Style="{StaticResource PremiumButton}"
                                    Background="{StaticResource SuccessBrush}"
                                    Click="Signup_Click"
                                    Height="48"
                                    FontSize="15"
                                    Margin="0"/>

                            <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Padding="15" Margin="0,22,0,0">
                                <TextBlock Foreground="{StaticResource PrimaryBrush}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Text="Demo codes: FLASH-MONTH-2026, FLASH-YEAR-2026, FLASH-LIFE-2026"/>
                            </Border>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- MAIN APP -->
        <Grid x:Name="AppGrid" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="22,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="82"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="50" Height="50" Background="{StaticResource PrimaryBrush}" CornerRadius="15" Margin="0,0,12,0">
                            <Path Data="{StaticResource IconBolt}" Fill="White" Width="24" Height="24" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="AI Flashcard Maker" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="v7.4.1" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-6,0" Padding="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="WORKSPACE" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,4,0,8"/>

                            <Button x:Name="NavDashboard" Style="{StaticResource NavButton}" Click="Dashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconHome}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavGenerate" Style="{StaticResource NavButton}" Click="GeneratePage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconGenerate}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Generate" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavImport" Style="{StaticResource NavButton}" Click="ImportPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconImport}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Import JSON" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavDecks" Style="{StaticResource NavButton}" Click="DecksPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconDecks}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="My Decks" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavStudy" Style="{StaticResource NavButton}" Click="StudyPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconStudy}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Study Mode" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavPreview" Style="{StaticResource NavButton}" Click="PreviewPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconEdit}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Preview / Edit" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavExport" Style="{StaticResource NavButton}" Click="ExportPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconExport}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="RESEARCH" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,14,0,8"/>

                            <Button x:Name="NavResearch" Style="{StaticResource NavButton}" Click="ResearchPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconResearch}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Research Lab" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="SYSTEM" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold" Margin="0,14,0,8"/>

                            <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Click="SettingsPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconSettings}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="AI Settings" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavAccount" Style="{StaticResource NavButton}" Click="AccountPage_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconAccount}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center"/>
                                    <TextBlock Text="Account" Margin="14,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Padding="14" Margin="0,12,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="SidebarStreakGif"
                                       Source="/Assets/Animations/streakfire.gif"
                                       Width="34"
                                       Height="34"
                                       VerticalAlignment="Center"
                                       Stretch="Uniform"/>
                                <TextBlock Text="Keep your streak" Foreground="{StaticResource TextBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Review due cards daily for long-term retention."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT APP AREA -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="82"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <Border Grid.Row="0" Background="{StaticResource AppBgBrush}" Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="14,0" MaxWidth="420" MinWidth="150" Height="44"
                                HorizontalAlignment="Left"
                                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSearch}" Fill="{StaticResource SoftMutedBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox x:Name="TopSearchBox"
                                         Grid.Column="1"
                                         Style="{StaticResource SearchBoxInner}"
                                         local:Watermark.Text="Search decks, cards, tags…"
                                         TextChanged="TopSearch_Changed"
                                         KeyDown="TopSearch_KeyDown"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Badge}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconAccount}" Fill="{StaticResource PrimaryBrush}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="UserSummaryText"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Column="2"
                                Content="Logout"
                                Style="{StaticResource GhostButton}"
                                Click="Logout_Click"
                                Margin="14,0,0,0"/>
                    </Grid>
                </Border>

                <!-- CONTENT -->
                <Grid Grid.Row="1" Margin="24,10,24,14" x:Name="ContentRoot">

                    <!-- DASHBOARD -->
                    <Grid x:Name="PageDashboard">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="330"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CardBorder}" Padding="28" Margin="0,0,18,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="170"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Welcome back" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="Your flashcard workspace is ready. Create decks, generate cards, and review due cards."
                                                           Foreground="{StaticResource MutedBrush}"
                                                           FontSize="15"
                                                           TextWrapping="Wrap"
                                                           Margin="0,10,0,20"/>

                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Generate Cards" Style="{StaticResource PremiumButton}" Click="GeneratePage_Click" Width="150"/>
                                                    <Button Content="Study Now" Style="{StaticResource SoftButton}" Click="StudyPage_Click" Width="120"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Image x:Name="DashboardStudyGif"
                                                   Grid.Column="1"
                                                   Source="/Assets/Animations/Study.gif"
                                                   Width="138"
                                                   Height="138"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="22">
                                        <StackPanel>
                                            <TextBlock Text="Study streak" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                                <Image x:Name="DashboardStreakGif"
                                                       Source="/Assets/Animations/streakfire.gif"
                                                       Width="64"
                                                       Height="64"
                                                       Stretch="Uniform"
                                                       Margin="0,0,14,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="StatsStreak" Text="0 days" Foreground="{StaticResource WarningBrush}" FontSize="28" FontWeight="Bold"/>
                                                    <TextBlock Text="Keep reviewing daily" Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <UniformGrid Columns="4" Margin="0,0,0,18">
                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                                        <StackPanel>
                                            <Border Background="{StaticResource PrimarySoftBrush}" Width="42" Height="42" CornerRadius="10" HorizontalAlignment="Left">
                                                <Path Data="{StaticResource IconDecks}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="StatsDecks" Text="0" Foreground="{StaticResource TextBrush}" FontSize="32" FontWeight="Bold" Margin="0,12,0,0"/>
                                            <TextBlock Text="Decks" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                                        <StackPanel>
                                            <Border Background="{StaticResource InfoSoftBrush}" Width="42" Height="42" CornerRadius="10" HorizontalAlignment="Left">
                                                <Path Data="{StaticResource IconCards}" Fill="{StaticResource InfoBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="StatsTotalCards" Text="0" Foreground="{StaticResource TextBrush}" FontSize="32" FontWeight="Bold" Margin="0,12,0,0"/>
                                            <TextBlock Text="Total cards" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                                        <StackPanel>
                                            <Border Background="{StaticResource SuccessSoftBrush}" Width="42" Height="42" CornerRadius="10" HorizontalAlignment="Left">
                                                <Path Data="{StaticResource IconCheck}" Fill="{StaticResource SuccessBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="StatsDueCards" Text="0" Foreground="{StaticResource SuccessBrush}" FontSize="32" FontWeight="Bold" Margin="0,12,0,0"/>
                                            <TextBlock Text="Due today" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <Border Background="{StaticResource WarningSoftBrush}" Width="42" Height="42" CornerRadius="10" HorizontalAlignment="Left">
                                                <Path Data="{StaticResource IconBook}" Fill="{StaticResource WarningBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock x:Name="StatsStudiedToday" Text="0" Foreground="{StaticResource PrimaryBrush}" FontSize="32" FontWeight="Bold" Margin="0,12,0,0"/>
                                            <TextBlock Text="Studied today" Foreground="{StaticResource MutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.58*"/>
                                        <ColumnDefinition Width="0.42*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource CardBorder}" Margin="0,0,18,0">
                                        <StackPanel>
                                            <TextBlock Text="Study performance" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Your progress summary across all local decks."
                                                       Foreground="{StaticResource MutedBrush}"
                                                       Margin="0,4,0,18"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Accuracy" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock x:Name="StatsAccuracy" Text="0%" Foreground="{StaticResource PrimaryBrush}" FontSize="30" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="1" Background="{StaticResource DangerSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Weak cards" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock x:Name="StatsWeak" Text="0" Foreground="{StaticResource DangerBrush}" FontSize="30" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Background="{StaticResource SuccessSoftBrush}" CornerRadius="12" Padding="18">
                                                    <StackPanel>
                                                        <TextBlock Text="Mode" Foreground="{StaticResource MutedBrush}"/>
                                                        <TextBlock Text="SRS" Foreground="{StaticResource SuccessBrush}" FontSize="30" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Image x:Name="DashboardSuccessGif"
                                                   Source="/Assets/Animations/Success.gif"
                                                   Width="74"
                                                   Height="74"
                                                   Stretch="Uniform"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Recommended next step" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="Create a topic deck, paste your notes, then generate cards with Z.ai."
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,14"/>
                                                <Button Content="Go to Generate" Style="{StaticResource PremiumButton}" Click="GeneratePage_Click" Width="140"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- GENERATE -->
                    <Grid x:Name="PageGenerate" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="112"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Generate Flashcards" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Choose a deck, paste notes, and generate high-yield flashcards with Z.ai."
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource SoftCardBorder}" Padding="16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="1.45*"/>
                                    <ColumnDefinition Width="1.0*"/>
                                    <ColumnDefinition Width="0.95*"/>
                                    <ColumnDefinition Width="0.72*"/>
                                    <ColumnDefinition Width="1.05*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Deck" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="GenerateDeckCombo" Height="44" SelectionChanged="DeckSelector_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Mode" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="ModeCombo" Height="44"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Difficulty" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="DifficultyCombo" Height="44"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                    <TextBlock Text="Answer" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="AnswerLengthCombo" Height="44"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                    <TextBlock Text="Count" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="CountCombo" Height="44"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5">
                                    <TextBlock Text="Language" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <ComboBox x:Name="LanguageCombo" Height="44"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.66*"/>
                                <ColumnDefinition Width="0.34*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,18,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="62"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Source Material" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Paste your notes below and Z.ai will turn them into high-yield flashcards." Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBox x:Name="SourceBox"
                                             Grid.Row="1"
                                             Style="{StaticResource EditorTextBox}"
                                             FontSize="14"
                                             local:Watermark.Text="Paste lecture notes, textbook text, a summary, or any source material here…"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Generate Flashcards" Style="{StaticResource PremiumButton}" Click="GenerateAutomatic_Click" Width="180"/>
                                        <Button Content="Create Manual Prompt" Style="{StaticResource SoftButton}" Click="CreatePrompt_Click" Width="190"/>
                                        <Button Content="Clear" Style="{StaticResource GhostButton}" Click="ClearSource_Click" Width="90"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="62"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,0,12">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="Manual Prompt Backup" Style="{StaticResource SectionHeader}"/>
                                        </StackPanel>
                                        <TextBlock Text="Create a backup prompt to use when automatic generation is unavailable." Style="{StaticResource Caption}" Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <TextBox x:Name="PromptBox"
                                             Grid.Row="1"
                                             Style="{StaticResource EditorTextBox}"
                                             local:Watermark.Text="Your backup prompt will appear here after you click Create Manual Prompt. You can also edit it before copying."/>

                                    <Button Grid.Row="2"
                                            Content="Copy Prompt"
                                            Style="{StaticResource PremiumButton}"
                                            Click="CopyPrompt_Click"
                                            Width="140"
                                            VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- IMPORT -->
                    <Grid x:Name="PageImport" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Import JSON" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Paste flashcard JSON generated by any AI model. Cards are added to the selected deck."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource SoftCardBorder}" Padding="14,0" Height="64" Margin="0,2,0,12">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Import into deck" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ComboBox x:Name="ImportDeckCombo" Width="300" SelectionChanged="DeckSelector_SelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.66*"/>
                                <ColumnDefinition Width="0.34*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,18,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="60"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Paste JSON" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Expected: an array of objects with front, back, and tags fields." Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBox x:Name="ImportBox"
                                             Grid.Row="1"
                                             Style="{StaticResource EditorTextBox}"
                                             FontFamily="Consolas"
                                             local:Watermark.Text="[ { &quot;front&quot;: &quot;Question…&quot;, &quot;back&quot;: &quot;Answer…&quot;, &quot;tags&quot;: &quot;topic&quot; } ]"/>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Import Cards" Style="{StaticResource PremiumButton}" Click="ImportCards_Click" Width="140"/>
                                        <Button Content="Clear" Style="{StaticResource GhostButton}" Click="ClearImport_Click" Width="90"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="82"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Current Deck Cards" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                                    <Border Grid.Row="1" Background="{StaticResource InfoSoftBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Image x:Name="ImportUploadGif"
                                                   Source="/Assets/Animations/Upload.gif"
                                                   Width="46"
                                                   Height="46"
                                                   Stretch="Uniform"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Imported cards are added to the active deck."
                                                       Foreground="{StaticResource InfoBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <ListBox x:Name="ImportedList" SelectionChanged="ImportedList_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="2,4">
                                                        <TextBlock Text="{Binding FrontLine}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding BackLine}" FontSize="12" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <StackPanel IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasItems, ElementName=ImportedList}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="No cards in this deck yet" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Paste JSON and import to add cards." Style="{StaticResource Caption}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock x:Name="ImportSummaryText" Grid.Row="3" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- DECKS -->
                    <Grid x:Name="PageDecks" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="72"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="My Decks" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Create decks, search cards, move cards, and start focused study sessions."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Group A: Deck actions -->
                        <Border Grid.Row="1" Style="{StaticResource SoftCardBorder}" Padding="16,12" Margin="0,2,0,10">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="DECK ACTIONS" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Width="108"/>
                                <TextBox x:Name="DeckNameBox" Height="42" Width="240" Margin="0,0,10,0"
                                         local:Watermark.Text="New deck name…"/>
                                <Button Content="Create Deck" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="CreateDeck_Click" Width="130"/>
                                <Button Content="Rename" Style="{StaticResource SoftButton}" Click="RenameDeck_Click" Width="110"/>
                                <Button Content="Delete Deck" Style="{StaticResource DangerSoftButton}" Click="DeleteDeck_Click" Width="130"/>
                            </StackPanel>
                        </Border>

                        <!-- Group B: Search / filter -->
                        <Border Grid.Row="2" Style="{StaticResource SoftCardBorder}" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="SEARCH &amp; FILTER" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Width="108"/>
                                <TextBox x:Name="SearchBox" Height="42" Width="240" Margin="0,0,10,0"
                                         local:Watermark.Text="Search cards…" TextChanged="SearchFilter_Changed"/>
                                <TextBox x:Name="TagFilterBox" Height="42" Width="180" Margin="0,0,18,0"
                                         local:Watermark.Text="Tag filter…" TextChanged="SearchFilter_Changed"/>
                                <CheckBox x:Name="DueOnlyCheck" Content="Due only" VerticalAlignment="Center" Checked="DueOnly_Checked" Unchecked="DueOnly_Checked"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.32*"/>
                                <ColumnDefinition Width="0.68*"/>
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardBorder}" Margin="0,0,18,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="72"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Deck Library" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>
                                    <ListBox x:Name="DeckList" Grid.Row="1" SelectionChanged="DeckList_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,4">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding CardsLabel}" FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding LastStudiedLabel}" FontSize="11" Foreground="{StaticResource SoftMutedBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="Study" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="StudySelectedDeck_Click" Width="95"/>
                                        <Button Content="Export" Style="{StaticResource SoftButton}" Click="ExportSelectedDeck_Click" Width="95"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="76"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="DeckSummaryText" Style="{StaticResource SectionHeader}" Margin="0,0,0,12"/>

                                    <Grid Grid.Row="1">
                                        <ListBox x:Name="CardsList" SelectionChanged="CardsList_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="2,4">
                                                        <TextBlock Text="{Binding FrontLine}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding BackLine}" FontSize="12" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <StackPanel IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasItems, ElementName=CardsList}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Path Data="{StaticResource IconCards}" Fill="{StaticResource SoftMutedBrush}" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"/>
                                            <TextBlock Text="No cards in this deck yet" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,2"/>
                                            <TextBlock Text="Generate or import cards to get started." Style="{StaticResource Caption}" TextAlignment="Center" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*" MinWidth="88"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Content="Preview Selected" Style="{StaticResource SoftButton}" Click="PreviewSelected_Click" Width="138"/>
                                        <Button Grid.Column="1" Content="Delete Selected" Style="{StaticResource DangerSoftButton}" Click="DeleteSelected_Click" Width="138"/>

                                        <TextBlock Grid.Column="2" Text="Move to" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="4,0,8,0"/>
                                        <ComboBox Grid.Column="3" x:Name="MoveDeckCombo" MinWidth="88" MaxWidth="220" Margin="0,0,10,0"/>
                                        <Button Grid.Column="4" Content="Move" Style="{StaticResource SoftButton}" Click="MoveSelected_Click" Width="88"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- STUDY -->
                    <Grid x:Name="PageStudy" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Study Mode" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Reveal the answer, then rate your memory with Again / Hard / Good / Easy."
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource SoftCardBorder}" Padding="14,0" VerticalAlignment="Stretch" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Study deck" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ComboBox x:Name="StudyDeckCombo" Width="320" SelectionChanged="DeckSelector_SelectionChanged"/>
                                <Button Content="Restart Session" Style="{StaticResource SoftButton}" Click="StudySelectedDeck_Click" Width="155" Margin="16,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="56,10" Padding="30,24">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="74"/>
                                </Grid.RowDefinitions>

                                <!-- Progress header -->
                                <StackPanel Grid.Row="0" Margin="0,0,0,4">
                                    <TextBlock x:Name="StudyProgressText" Text="No cards" Foreground="{StaticResource MutedBrush}" FontSize="15" FontWeight="SemiBold"/>
                                    <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="5" Height="8" Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="StudyProgFilledCol" Width="0*"/>
                                                <ColumnDefinition x:Name="StudyProgEmptyCol" Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" CornerRadius="5"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border x:Name="StudyCardSurface" Grid.Row="1" Background="{StaticResource SoftCardBrush}" CornerRadius="18" Padding="30,24" Margin="0,18,0,0"
                                        RenderTransformOrigin="0.5,0.5">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="StudyFrontText"
                                                   Text="No card selected."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"/>

                                        <Border x:Name="StudyAnswerPanel"
                                                Visibility="Collapsed"
                                                Background="{StaticResource CardBrush}"
                                                CornerRadius="16"
                                                Padding="20,18"
                                                Margin="0,20,0,0">
                                            <TextBlock x:Name="StudyBackText"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       FontSize="19"
                                                       TextAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="StudyHintText" Grid.Row="2" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,16,0,0" TextAlignment="Center"/>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button x:Name="BtnShowAnswer" Content="Show Answer" Style="{StaticResource PremiumButton}" Click="ShowAnswer_Click" Width="150"/>
                                    <Button x:Name="BtnAgain" Content="Again" Style="{StaticResource PremiumButton}" Background="{StaticResource DangerBrush}" Click="Again_Click" Width="100"/>
                                    <Button x:Name="BtnHard" Content="Hard" Style="{StaticResource PremiumButton}" Background="{StaticResource WarningBrush}" Click="Hard_Click" Width="100"/>
                                    <Button x:Name="BtnGood" Content="Good" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="Good_Click" Width="100"/>
                                    <Button x:Name="BtnEasy" Content="Easy" Style="{StaticResource PremiumButton}" Background="{StaticResource InfoBrush}" Click="Easy_Click" Width="100"/>
                                </StackPanel>

                                <!-- Session complete overlay -->
                                <Border x:Name="StudyCompletePanel"
                                        Grid.RowSpan="4"
                                        Visibility="Collapsed"
                                        Background="{StaticResource CardBrush}"
                                        CornerRadius="18">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Border Width="120" Height="120" Background="{StaticResource SuccessSoftBrush}" CornerRadius="30" HorizontalAlignment="Center">
                                            <Image x:Name="StudyCompleteGif"
                                                   Source="/Assets/Animations/Success.gif"
                                                   Width="92"
                                                   Height="92"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Text="Session complete"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,18,0,6"/>

                                        <TextBlock x:Name="StudyCompleteSubtitle"
                                                   Text="Great work. No more due cards in this session."
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="15"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="440"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                                            <Button Content="Study Again" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="StudySelectedDeck_Click" Width="150"/>
                                            <Button Content="Back to Dashboard" Style="{StaticResource SoftButton}" Click="Dashboard_Click" Width="180"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- PREVIEW -->
                    <Grid x:Name="PagePreview" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Preview / Edit" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Edit the selected card’s front, back, and tags."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="CardCounterText" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>

                                <Grid Grid.Row="1" Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Front (question)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="FrontBox"
                                             Grid.Row="1"
                                             Style="{StaticResource EditorTextBox}"
                                             local:Watermark.Text="The question or cloze prompt shown on the front of the card…"/>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,0,0,14">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Back (answer)" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="BackBox"
                                             Grid.Row="1"
                                             Style="{StaticResource EditorTextBox}"
                                             local:Watermark.Text="The answer revealed on the back of the card…"/>
                                </Grid>

                                <StackPanel Grid.Row="3" Margin="0,0,0,16">
                                    <TextBlock Text="Tags" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TagsBox" Height="46"
                                             local:Watermark.Text="e.g. Step1::Cardiology (use :: for hierarchy)"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Previous" Style="{StaticResource SoftButton}" Click="Previous_Click" Width="110"/>
                                    <Button Content="Next" Style="{StaticResource SoftButton}" Click="Next_Click" Width="90"/>
                                    <Button Content="Save" Style="{StaticResource PremiumButton}" Click="SaveCard_Click" Width="90"/>
                                    <Button Content="Delete" Style="{StaticResource DangerSoftButton}" Click="DeleteCard_Click" Width="100"/>
                                    <Button Content="Copy Current" Style="{StaticResource SoftButton}" Click="CopyCurrent_Click" Width="150"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Orientation="Horizontal">
                                    <Button Content="Copy All For Anki" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="CopyAll_Click" Width="180"/>
                                    <Button Content="Export Selected Deck" Style="{StaticResource SoftButton}" Click="ExportSelectedDeck_Click" Width="180"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- EXPORT -->
                    <Grid x:Name="PageExport" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="62"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Export" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Export selected deck or all decks as tab-separated fields for Anki."
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>

                        <Border Grid.Row="1" Style="{StaticResource SoftCardBorder}" Padding="14,0" VerticalAlignment="Stretch" Margin="0,0,0,2">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Export deck" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ComboBox x:Name="ExportDeckCombo" Width="320" SelectionChanged="DeckSelector_SelectionChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Export Preview" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Preview tab-separated cards before copying or exporting." Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1">
                                        <TextBox x:Name="ExportPreviewBox"
                                                 Style="{StaticResource EditorTextBox}"
                                                 IsReadOnly="True"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 FontSize="13"
                                                 HorizontalScrollBarVisibility="Auto"/>

                                        <StackPanel IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ExportPreviewBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Path Data="{StaticResource IconExport}" Fill="{StaticResource SoftMutedBrush}" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Nothing to preview yet" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,2"/>
                                            <TextBlock Text="Select a deck with cards, then Refresh Preview." Style="{StaticResource Caption}" TextAlignment="Center" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <Border Grid.Column="1" Background="{StaticResource SuccessSoftBrush}" CornerRadius="14" Padding="18" Margin="18,0,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <Border Width="72" Height="72" Background="White" CornerRadius="20" HorizontalAlignment="Center">
                                            <Path Data="{StaticResource IconExport}" Fill="{StaticResource SuccessBrush}" Width="34" Height="34" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Ready to export" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,14,0,12"/>
                                        <TextBlock Text="Selected deck" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedItem.Name, ElementName=ExportDeckCombo}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,1,0,10"/>
                                        <TextBlock Text="{Binding SelectedItem.CardsLabel, ElementName=ExportDeckCombo}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" TextAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Copy or save your cards for Anki." Style="{StaticResource Caption}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource SoftCardBorder}" Padding="14,0" VerticalAlignment="Stretch" Margin="0,2,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Refresh Preview" Style="{StaticResource GhostButton}" Click="RefreshExport_Click" Width="150"/>
                                <Button Content="Copy Selected Deck" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="CopySelectedDeck_Click" Width="180"/>
                                <Button Content="Copy All Decks" Style="{StaticResource SoftButton}" Click="CopyAll_Click" Width="150"/>
                                <Button Content="Export Selected" Style="{StaticResource PremiumButton}" Click="ExportSelectedDeck_Click" Width="155"/>
                                <Button Content="Export All" Style="{StaticResource SoftButton}" Click="ExportAllDecks_Click" Width="120"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- SETTINGS -->
                    <Grid x:Name="PageSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="AI Settings" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Configure your Z.ai provider used to generate flashcards."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,4,0,16">
                                    <StackPanel MaxWidth="920" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                            <Border Width="50" Height="50" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                                <Path Data="{StaticResource IconSettings}" Fill="{StaticResource PrimaryBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Z.ai provider" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Credentials are stored locally on this device." Style="{StaticResource Caption}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="API key" Style="{StaticResource FieldLabel}"/>
                                        <PasswordBox x:Name="ApiKeyBox" Height="48"/>
                                        <TextBlock Text="Kept on this computer only and sent solely to Z.ai when generating cards. Never displayed after saving."
                                                   Style="{StaticResource Caption}" Margin="2,6,0,18"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Model" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="ModelBox" Height="48"/>
                                                <TextBlock Text="e.g. GLM-4.7-FlashX" Style="{StaticResource Caption}" Margin="2,6,0,18"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="Base URL" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="BaseUrlBox" Height="48"/>
                                                <TextBlock Text="The Z.ai API endpoint used for requests." Style="{StaticResource Caption}" Margin="2,6,0,18"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Save Settings" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="SaveSettings_Click" Width="150"/>
                                            <Button Content="Clear Key" Style="{StaticResource DangerSoftButton}" Click="ClearKey_Click" Width="120"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="12" Padding="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Data="{StaticResource IconSettings}" Fill="{StaticResource WarningBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Top" Margin="0,1,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="This local API key setup is intended for testing. A production release should route generation through a backend so the key is never exposed to users."
                                                   Foreground="{StaticResource WarningBrush}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                </Border>

                                <!-- Research AI (separate from flashcard AI; no provider keys here) -->
                                <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,16,0,0">
                                    <StackPanel MaxWidth="920" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <Border Width="50" Height="50" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                                <Path Data="{StaticResource IconResearch}" Fill="{StaticResource PrimaryBrush}" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Research AI" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Used by the Research Lab. Connects to your own backend endpoint — no provider keys are stored in this app." Style="{StaticResource Caption}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="Research AI endpoint URL" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="RaiEndpointBox" Height="48" local:Watermark.Text="https://your-backend.example.com"/>
                                        <TextBlock Text="Your backend/proxy base URL. The app calls /api/research-ai/recommendations and /api/research-ai/proposal. Leave blank if you don't have one yet."
                                                   Style="{StaticResource Caption}" Margin="2,6,0,18"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Timeout (seconds)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="RaiTimeoutBox" Height="48" Text="900"/>
                                                <TextBlock Text="Default 900s (15 min). Complex tasks may take longer — raise up to 2700s (45 min) if needed."
                                                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="2,6,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom">
                                                <CheckBox x:Name="RaiMockToggle" Content="Use development mock (generate sample drafts offline, no backend)"
                                                          VerticalAlignment="Center" Margin="0,0,0,12"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Development-only. Provider-neutral by design: no provider name is shown.
                                             When enabled, in-app generation reuses the API key already saved in the
                                             flashcard AI Settings; no key is stored in this card. Production uses the
                                             backend endpoint above instead. -->
                                        <StackPanel Margin="0,4,0,0">
                                            <CheckBox x:Name="RaiDevProviderToggle"
                                                      Content="Use connected AI provider for development testing (uses your saved AI provider key)"/>
                                            <TextBlock Text="For local development and testing only. Reuses the API key you already saved in AI Settings — no key is stored here. In production, Research AI uses the backend endpoint above."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="26,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                            <Button Content="Save Research AI Settings" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="SaveResearchAiConfig_Click" Width="230"/>
                                            <Button x:Name="RaiTestBtn" Content="Test Research AI" Style="{StaticResource SoftButton}" Click="TestResearchAi_Click" Width="170" Margin="12,0,0,0"/>
                                        </StackPanel>

                                        <Border x:Name="RaiTestResult" CornerRadius="10" Padding="14,11" Margin="0,12,0,0" Visibility="Collapsed" Background="{StaticResource SoftCardBrush}">
                                            <TextBlock x:Name="RaiTestResultText" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                        </Border>

                                        <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="12" Padding="16" Margin="0,18,0,0">
                                            <TextBlock Text="Do not enter any AI provider API keys here. Provider secrets belong only on your backend. This app only sends structured project data to the endpoint above."
                                                       Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ACCOUNT -->
                    <Grid x:Name="PageAccount" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Account" Style="{StaticResource PageTitle}"/>
                            <TextBlock Text="Your local account and subscription information."
                                       Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,4,0,16">
                                    <StackPanel MaxWidth="920" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                                            <Border Width="60" Height="60" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Margin="0,0,16,0">
                                                <Path Data="{StaticResource IconAccount}" Fill="{StaticResource PrimaryBrush}" Width="30" Height="30" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Subscription details" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Local demo activation — backend login comes later." Style="{StaticResource Caption}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Grid Margin="0,0,0,24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Padding="16,14" Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="EMAIL" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AccountEmailText" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Background="{StaticResource SuccessSoftBrush}" CornerRadius="12" Padding="16,14" Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="PLAN" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AccountPlanText" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" Background="{StaticResource InfoSoftBrush}" CornerRadius="12" Padding="16,14">
                                                <StackPanel>
                                                    <TextBlock Text="EXPIRES" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AccountExpiryText" Foreground="{StaticResource InfoBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Apply new activation code" Style="{StaticResource FieldLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ApplyCodeBox" Height="48" Margin="0,0,12,0"
                                                     local:Watermark.Text="Enter a new activation code (e.g. FLASH-YEAR-2026)"/>
                                            <Button Grid.Column="1" Content="Apply Code" Style="{StaticResource PremiumButton}" Background="{StaticResource SuccessBrush}" Click="ApplyCode_Click" Width="130"/>
                                        </Grid>

                                        <Button Content="Log out" Style="{StaticResource GhostButton}" Click="Logout_Click" Width="120" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource DangerSoftBrush}" CornerRadius="12" Padding="18">
                                    <TextBlock Text="This is not a real online subscription system yet. A future release will add backend login, verified activation codes, and secure subscription checks."
                                               Foreground="{StaticResource DangerBrush}"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ================================================ -->
                    <!-- RESEARCH LAB — PROJECT LIST                       -->
                    <!-- ================================================ -->
                    <Grid x:Name="PageResearch" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="76"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Research Lab" Style="{StaticResource PageTitle}"/>
                                <TextBlock Text="Plan, analyze, and write research projects in one workspace."
                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Create New Research Project"
                                    Style="{StaticResource PremiumButton}" Width="250" Margin="0"
                                    VerticalAlignment="Center" Click="OpenCreateProject_Click"/>
                        </Grid>

                        <!-- Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <!-- Empty state -->
                                <Border x:Name="ResearchEmptyState" Style="{StaticResource SoftCardBorder}" Padding="40" Margin="0,4,0,0" VerticalAlignment="Top">
                                    <StackPanel HorizontalAlignment="Center" MaxWidth="540">
                                        <Border Width="76" Height="76" Background="{StaticResource PrimarySoftBrush}" CornerRadius="20" HorizontalAlignment="Center">
                                            <Path Data="{StaticResource IconResearch}" Fill="{StaticResource PrimaryBrush}" Width="38" Height="38" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="No research projects yet" Style="{StaticResource SectionHeader}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                                        <TextBlock Text="Create your first project to start building a proposal, extraction sheet, statistics plan, and manuscript."
                                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                                        <Button Content="Create New Research Project" Style="{StaticResource PremiumButton}"
                                                Width="250" HorizontalAlignment="Center" Margin="0,22,0,0" Click="OpenCreateProject_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Project cards -->
                                <ItemsControl x:Name="ResearchCardsHost" Visibility="Collapsed">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,4,0,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>

                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding SpecialtyDisplay}" Foreground="{StaticResource PrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border Background="{StaticResource InfoSoftBrush}" CornerRadius="7" Padding="10,5" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding StudyTypeDisplay}" Foreground="{StaticResource InfoBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border Background="{StaticResource SuccessSoftBrush}" CornerRadius="7" Padding="10,5">
                                                                <TextBlock Text="{Binding StageDisplay}" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" VerticalAlignment="Center">
                                                            <Border Width="170" Height="8" CornerRadius="4" Background="#ECEEF1" VerticalAlignment="Center">
                                                                <Border CornerRadius="4" Background="{StaticResource PrimaryBrush}" HorizontalAlignment="Left"
                                                                        Width="{Binding ProgressPercent, Converter={StaticResource PercentBarWidth}, ConverterParameter=170}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding ProgressDisplay}" Foreground="{StaticResource MutedBrush}" FontSize="12" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding UpdatedDisplay}" Foreground="{StaticResource SoftMutedBrush}" FontSize="12" Margin="18,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                                        <Button Content="Continue" Style="{StaticResource SoftButton}" Width="110" Tag="{Binding Id}" Click="ContinueProject_Click"/>
                                                        <Button Content="Delete" Style="{StaticResource DangerSoftButton}" Width="96" Margin="0" Tag="{Binding Id}" Click="DeleteProject_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>

                        <!-- Create-project modal overlay -->
                        <Grid x:Name="CreateProjectOverlay" Grid.RowSpan="2" Background="#8A1B1B2A" Visibility="Collapsed">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="660" MaxHeight="600"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Create New Research Project" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Set up the basics now — you can refine everything later inside the project dashboard."
                                                   Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,20,0">
                                        <StackPanel Margin="0,6,0,8">
                                            <TextBlock Text="Project title / idea *" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="RpTitleBox" local:Watermark.Text="e.g. Prevalence of anemia among first-year medical students"/>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Specialty" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="RpSpecialtyBox" local:Watermark.Text="e.g. Internal Medicine"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Study type" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="RpStudyTypeCombo">
                                                        <ComboBoxItem Content="Cross-sectional"/>
                                                        <ComboBoxItem Content="Case-control"/>
                                                        <ComboBoxItem Content="Cohort"/>
                                                        <ComboBoxItem Content="Retrospective"/>
                                                        <ComboBoxItem Content="Systematic review"/>
                                                        <ComboBoxItem Content="Meta-analysis"/>
                                                        <ComboBoxItem Content="Case report"/>
                                                        <ComboBoxItem Content="Not sure"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Research aim" Style="{StaticResource FieldLabel}" Margin="0,16,0,7"/>
                                            <TextBox x:Name="RpAimBox" Style="{StaticResource EditorTextBox}" MinHeight="64"
                                                     local:Watermark.Text="What question is this project trying to answer?"/>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Population" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="RpPopulationBox" local:Watermark.Text="e.g. Adults aged 18–45"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Setting" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="RpSettingBox" local:Watermark.Text="e.g. Teaching hospital, outpatient clinic"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Time period" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="RpTimePeriodBox" local:Watermark.Text="e.g. Jan–Jun 2026"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Available data" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="RpDataCombo">
                                                        <ComboBoxItem Content="Google Form"/>
                                                        <ComboBoxItem Content="Pasted questions"/>
                                                        <ComboBoxItem Content="Excel/CSV"/>
                                                        <ComboBoxItem Content="Manual entry"/>
                                                        <ComboBoxItem Content="No data yet"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Desired outputs" Style="{StaticResource FieldLabel}" Margin="0,16,0,9"/>
                                            <WrapPanel>
                                                <CheckBox x:Name="RpOutProposal" Content="Proposal" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutIntroduction" Content="Introduction" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutMethods" Content="Methods" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutExtraction" Content="Data Extraction Sheet" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutStatistics" Content="Statistics" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutManuscript" Content="Manuscript" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutAbstract" Content="Abstract" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="RpOutTables" Content="Tables" Margin="0,0,22,10"/>
                                            </WrapPanel>

                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}" Margin="0,10,0,7"/>
                                            <TextBox x:Name="RpNotesBox" Style="{StaticResource EditorTextBox}" MinHeight="64"
                                                     local:Watermark.Text="Optional notes, references, or reminders"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Border Grid.Row="2" Background="{StaticResource SoftCardBrush}" CornerRadius="0,0,14,14"
                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="RpValidationText" Grid.Column="0" Foreground="{StaticResource DangerBrush}"
                                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"
                                                       Margin="0,0,14,0" Visibility="Collapsed"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Cancel" Style="{StaticResource GhostButton}" Width="110" Click="CancelCreateProject_Click"/>
                                                <Button Content="Create Project" Style="{StaticResource PremiumButton}" Width="160" Margin="0" Click="CreateProject_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Delete-confirm overlay -->
                        <Grid x:Name="DeleteConfirmOverlay" Grid.RowSpan="2" Background="#8A1B1B2A" Visibility="Collapsed">
                            <Border Style="{StaticResource CardBorder}" Padding="28" Width="440"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Delete research project?" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock x:Name="DeleteConfirmText"
                                               Text="This will permanently remove the project and its saved details. This cannot be undone."
                                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                                        <Button Content="Cancel" Style="{StaticResource GhostButton}" Width="110" Click="CancelDelete_Click"/>
                                        <Button Content="Delete Project" Style="{StaticResource DangerButton}" Width="160" Margin="0" Click="ConfirmDelete_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ================================================ -->
                    <!-- RESEARCH LAB — PROJECT DASHBOARD                  -->
                    <!-- ================================================ -->
                    <Grid x:Name="PageResearchDashboard" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Margin="0,0,0,16">
                            <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Padding="14,0" Margin="0,0,0,14" Click="BackToResearch_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M14 6 L8 12 L14 18 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Back to Research Lab" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="DashTitleText" Text="Project" Style="{StaticResource PageTitle}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DashSubtitleText" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Segmented tab bar -->
                        <Border Grid.Row="1" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1" CornerRadius="11" Padding="4" Margin="0,0,0,18" SnapsToDevicePixels="True">
                            <WrapPanel>
                                <Button x:Name="SegOverview" Content="Overview" Style="{StaticResource SegTabActive}" Tag="Overview" Click="ResearchTab_Click"/>
                                <Button x:Name="SegAiRec" Content="AI Recommendations" Style="{StaticResource SegTab}" Tag="AiRec" Click="ResearchTab_Click"/>
                                <Button x:Name="SegProposal" Content="Proposal" Style="{StaticResource SegTab}" Tag="Proposal" Click="ResearchTab_Click"/>
                                <Button x:Name="SegDataExt" Content="Data Extraction" Style="{StaticResource SegTab}" Tag="DataExt" Click="ResearchTab_Click"/>
                                <Button x:Name="SegStats" Content="Statistics" Style="{StaticResource SegTab}" Tag="Stats" Click="ResearchTab_Click"/>
                                <Button x:Name="SegResults" Content="Results" Style="{StaticResource SegTab}" Tag="Results" Click="ResearchTab_Click"/>
                                <Button x:Name="SegManuscript" Content="Manuscript" Style="{StaticResource SegTab}" Tag="Manuscript" Click="ResearchTab_Click"/>
                                <Button x:Name="SegNotes" Content="Notes" Style="{StaticResource SegTab}" Tag="Notes" Click="ResearchTab_Click"/>
                            </WrapPanel>
                        </Border>

                        <!-- Tab content -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid x:Name="DashTabHost">

                                <!-- OVERVIEW -->
                                <Grid x:Name="TabOverview">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="340"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Top">

                                    <!-- Details changed since recommendations (Phase 2E) -->
                                    <Border x:Name="OvDetailsChangedWarning" Background="{StaticResource WarningSoftBrush}" CornerRadius="12" Padding="16,14" Margin="0,0,0,16" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Project details changed" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="Consider regenerating AI recommendations so the research plan stays aligned."
                                                       Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorder}" Padding="26">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,18">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Project details" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Style="{StaticResource SoftButton}" Padding="14,8" Click="OpenEditProject_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconEdit}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Edit Project Details" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Title" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvTitle" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Specialty" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvSpecialty" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Study type" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvStudyType" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Aim" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvAim" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Population" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvPopulation" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Setting" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvSetting" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Time period" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvTimePeriod" Foreground="{StaticResource TextBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Current stage" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" x:Name="OvStage" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Recommended workflow -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Recommended workflow" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Everything happens inside the app." Style="{StaticResource Caption}" Margin="0,0,0,14"/>
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,9"><Run Text="1." FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/><Run Text="  Complete project details" Foreground="{StaticResource TextBrush}"/></TextBlock>
                                                <TextBlock Margin="0,0,0,9"><Run Text="2." FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/><Run Text="  Generate AI recommendations" Foreground="{StaticResource TextBrush}"/></TextBlock>
                                                <TextBlock Margin="0,0,0,9"><Run Text="3." FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/><Run Text="  Accept research plan" Foreground="{StaticResource TextBrush}"/></TextBlock>
                                                <TextBlock Margin="0,0,0,9"><Run Text="4." FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/><Run Text="  Generate proposal draft" Foreground="{StaticResource TextBrush}"/></TextBlock>
                                                <TextBlock Margin="0,0,0,9"><Run Text="5." FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/><Run Text="  Build data extraction sheet" Foreground="{StaticResource MutedBrush}"/></TextBlock>
                                                <TextBlock Margin="0,0,0,9"><Run Text="6." FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/><Run Text="  Run statistics" Foreground="{StaticResource MutedBrush}"/></TextBlock>
                                                <TextBlock><Run Text="7." FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/><Run Text="  Write manuscript" Foreground="{StaticResource MutedBrush}"/></TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Research Plan Readiness (Phase 2E) -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Research Plan Readiness" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                                            <TextBlock Text="What is complete before data extraction." Style="{StaticResource Caption}" Margin="0,0,0,16"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyTitleIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyTitleText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyDesignIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyDesignText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyQuestionIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyQuestionText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyObjectivesIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyObjectivesText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border x:Name="RdyVariablesIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyVariablesText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyAnalysesIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyAnalysesText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyCriteriaIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyCriteriaText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyEthicsIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyEthicsText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <Border x:Name="RdyAcceptedIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyAcceptedText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border x:Name="RdyProposalIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="RdyProposalText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Import Existing Proposal (Phase 2F) -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,16,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Width="40" Height="40" Background="{StaticResource PrimarySoftBrush}" CornerRadius="11" Margin="0,0,13,0" VerticalAlignment="Center">
                                                    <Path Data="{StaticResource IconImport}" Fill="{StaticResource PrimaryBrush}" Width="19" Height="19" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="Import Existing Proposal" Style="{StaticResource SectionHeader}"/>
                                                    <TextBlock Text="Already have a proposal? Let Research AI read it." Style="{StaticResource Caption}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="Upload or paste an existing proposal and let Research AI extract the project details, research plan, variables, analyses, and proposal sections."
                                                       Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,10,0,14"/>
                                            <Button Style="{StaticResource PremiumButton}" HorizontalAlignment="Left" Click="OpenImportProposal_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconImport}" Fill="White" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Import Existing Proposal" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <!-- Phase status -->
                                        <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,0,0,16">
                                            <StackPanel>
                                                <TextBlock Text="Phase status" Style="{StaticResource SectionHeader}" Margin="0,0,0,14"/>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Recommendations" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" x:Name="OvRecStatus" Text="Not started" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Research plan" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" x:Name="OvPlanStatus" Text="Not started" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Proposal draft" Foreground="{StaticResource SoftMutedBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" x:Name="OvProposalStatus" Text="Not started" Foreground="{StaticResource MutedBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardBorder}" Padding="22">
                                            <StackPanel>
                                                <TextBlock Text="Progress checklist" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkCreatedIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkCreatedText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkRecIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkRecText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkPlanIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkPlanText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkProposalIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkProposalText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkDataIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkDataText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="ChkStatsIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkStatsText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border x:Name="ChkManuscriptIcon" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ChkManuscriptText" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardBorder}" Background="{StaticResource PrimarySoftBrush}" BorderBrush="{StaticResource PrimarySoftBrush}" Padding="20" Margin="0,16,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Next best step" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="15"/>
                                                <TextBlock x:Name="DashNextStepText" Text="Next: generate or import AI recommendations."
                                                           Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Data extraction readiness (Phase 2E/D) -->
                                        <Border x:Name="OvReadyCard" CornerRadius="14" Padding="20" Margin="0,16,0,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Border x:Name="OvReadyIcon" Width="26" Height="26" CornerRadius="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="OvReadyTitle" Text="Ready for Data Extraction" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="OvReadyDetail" TextWrapping="Wrap" FontSize="13" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- PROPOSAL -->
                                <StackPanel x:Name="TabProposal" Visibility="Collapsed" MaxWidth="960" HorizontalAlignment="Left">

                                    <!-- Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Proposal" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Build a structured proposal draft from your project and accepted recommendations." Style="{StaticResource Caption}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Import Existing Proposal (Phase 2F) -->
                                    <Border Style="{StaticResource SoftCardBorder}" Padding="20" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <TextBlock Text="Already have a proposal?" Foreground="{StaticResource TextBrush}" FontSize="14.5" FontWeight="SemiBold"/>
                                                <TextBlock Text="Upload or paste an existing proposal and let Research AI extract the project details, research plan, variables, analyses, and proposal sections."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource PremiumButton}" VerticalAlignment="Center" Click="OpenImportProposal_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconImport}" Fill="White" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Import Existing Proposal" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Research Plan Source: accepted state -->
                                    <Border x:Name="ProposalPlanSourceAccepted" Background="{StaticResource SuccessSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,16" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="42" Height="42" Background="{StaticResource SuccessBrush}" CornerRadius="10" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Path Data="{StaticResource IconCheck}" Fill="White" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Research Plan Source" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="Bold"/>
                                                <TextBlock Text="Using accepted AI research plan" Foreground="{StaticResource TextBrush}" FontSize="14.5" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Research Plan Source: missing state -->
                                    <Border x:Name="ProposalPlanSourceMissing" Background="{StaticResource WarningSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,16" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Research Plan Source" Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="No accepted research plan yet" Foreground="{StaticResource TextBrush}" FontSize="14.5" FontWeight="SemiBold" Margin="0,2,0,6"/>
                                            <TextBlock Text="Generate and accept AI recommendations first for the best proposal draft." Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Go to AI Recommendations" Style="{StaticResource SoftButton}" Click="GoToAiRecommendations_Click" Margin="0,0,10,0"/>
                                                <Button x:Name="GenerateBasicProposalBtn" Content="Generate basic proposal from project details anyway" Style="{StaticResource SoftButton}" Click="GenerateBasicProposal_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Safety notice -->
                                    <Border Background="#FFF7ED" BorderBrush="#F5C98A" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                                        <TextBlock Text="AI-generated research text must be reviewed by you and your supervisor. Verify methods, ethics requirements, statistics, and references before use. The assistant does not write Results or Discussion and does not add citations."
                                                   Foreground="#9A5B12" FontSize="12.5" TextWrapping="Wrap"/>
                                    </Border>

                                    <!-- Proposal already generated (one-time generation guard) -->
                                    <Border x:Name="ProposalDraftExistsCard" Background="{StaticResource SuccessSoftBrush}" CornerRadius="12" Padding="18" Margin="0,0,0,16" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                                                <TextBlock Text="Proposal draft already generated." Foreground="{StaticResource SuccessBrush}" FontSize="14" FontWeight="Bold"/>
                                                <TextBlock Text="Edit the proposal sections below, or delete the draft to generate a new one. Generating again without deleting is disabled to avoid wasted AI usage."
                                                           Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Style="{StaticResource GhostButton}" VerticalAlignment="Center" MinWidth="170" Click="DeleteProposalDraft_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconTrash}" Fill="{StaticResource DangerBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                    <TextBlock Text="Delete Proposal Draft" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Generate (fully in-app) -->
                                    <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Create a draft" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Generate a structured proposal draft from your project details and accepted recommendations — right here in the app."
                                                       Style="{StaticResource Caption}" Margin="0,4,0,14" TextWrapping="Wrap"/>

                                            <Button x:Name="GenerateProposalBtn" Style="{StaticResource PremiumButton}" HorizontalAlignment="Left" Click="GenerateProposalDraft_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconGenerate}" Fill="White" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock x:Name="GenerateProposalBtnText" Text="Generate Proposal Draft" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Not-configured state -->
                                            <Border x:Name="ProposalNotConfigured" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="Research AI service is not configured yet" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" FontSize="13.5"/>
                                                    <TextBlock Text="Connect a Research AI backend endpoint in Settings to generate proposal drafts inside the app."
                                                               Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,6,0,10"/>
                                                    <Button Content="Open Research AI settings" Style="{StaticResource SoftButton}" HorizontalAlignment="Left" Click="OpenResearchAiSettings_Click"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Error state -->
                                            <Border x:Name="ProposalError" Background="{StaticResource DangerSoftBrush}" CornerRadius="10" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock x:Name="ProposalErrorText" Foreground="{StaticResource DangerBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <Button Content="Retry" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="GenerateProposalDraft_Click"/>
                                                        <Button Content="Open Research AI Settings" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="OpenResearchAiSettings_Click"/>
                                                        <Button Content="Open details" Style="{StaticResource GhostButton}" Click="ShowAiDiagnostics_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Editable proposal sections -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Proposal sections" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                                <Border x:Name="PropTemplateBadge" Background="{StaticResource PrimarySoftBrush}" CornerRadius="8" Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                                    <TextBlock Text="AI-generated draft — review before use" Foreground="{StaticResource PrimaryBrush}" FontSize="11.5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Edit any section, then save. Leave references for you to add and verify." Style="{StaticResource Caption}" Margin="0,2,0,4"/>

                                            <TextBlock Text="Title" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropTitle" Style="{StaticResource EditorTextBox}"/>
                                            <TextBlock Text="Background" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropBackground" Style="{StaticResource EditorTextBox}" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Rationale" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropRationale" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Aim" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropAim" Style="{StaticResource EditorTextBox}" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Study design" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropStudyDesign" Style="{StaticResource EditorTextBox}" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Objectives" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropObjectives" Style="{StaticResource EditorTextBox}" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Methods" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropMethods" Style="{StaticResource EditorTextBox}" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Setting" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropSetting" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Population" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropPopulation" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Inclusion criteria" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropInclusion" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Exclusion criteria" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropExclusion" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Variables" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropVariables" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Data collection" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropDataCollection" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Statistical analysis plan" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropStatsPlan" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Ethics" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="PropEthics" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Timeline" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropTimeline" Style="{StaticResource EditorTextBox}" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Limitations" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="PropLimitations" Style="{StaticResource EditorTextBox}" MinHeight="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border x:Name="PropRawCard" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,16,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="Imported text (unstructured)" Foreground="{StaticResource SoftMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                                    <TextBox x:Name="PropRawText" Style="{StaticResource EditorTextBox}" MinHeight="120" MaxHeight="260"
                                                             IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Content="Save Proposal Draft" Style="{StaticResource PremiumButton}" Width="180" HorizontalAlignment="Left" Margin="0,18,0,0" Click="SaveProposal_Click"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <!-- AI RECOMMENDATIONS -->
                                <StackPanel x:Name="TabAiRec" Visibility="Collapsed" MaxWidth="960" HorizontalAlignment="Left">

                                    <!-- Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                        <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                            <Path Data="{StaticResource IconGenerate}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="AI Recommendations" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Get structured guidance for study design, objectives, variables, analyses, and next steps." Style="{StaticResource Caption}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- A. Project snapshot -->
                                    <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Project snapshot" Style="{StaticResource SectionHeader}" Margin="0,0,0,16"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="TITLE" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapTitle" Foreground="{StaticResource TextBrush}" FontSize="13.5" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                                    <TextBlock Text="STUDY TYPE" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapStudyType" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                                    <TextBlock Text="POPULATION" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapPopulation" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                                    <TextBlock Text="AVAILABLE DATA" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapData" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="SPECIALTY" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapSpecialty" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                                    <TextBlock Text="AIM" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapAim" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                                    <TextBlock Text="SETTING" Foreground="{StaticResource SoftMutedBrush}" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock x:Name="AiSnapSetting" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- B. Generate (fully in-app) -->
                                    <Border Style="{StaticResource CardBorder}" Padding="24" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="AI Research Assistant" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Generate structured recommendations for this project — study design, objectives, variables, analyses, and next steps — right here in the app."
                                                       Style="{StaticResource Caption}" Margin="0,4,0,14" TextWrapping="Wrap"/>

                                            <!-- Based on imported proposal (Phase 2F) -->
                                            <Border x:Name="AiRecImportedBadge" Background="{StaticResource SuccessSoftBrush}" CornerRadius="10" Padding="14,11" Margin="0,0,0,14" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="30" Height="30" Background="{StaticResource SuccessBrush}" CornerRadius="8" Margin="0,0,11,0" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource IconCheck}" Fill="White" Width="15" Height="15" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Recommendations are based on the imported proposal." Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Button x:Name="GenerateRecBtn" Style="{StaticResource PremiumButton}" HorizontalAlignment="Left" Click="GenerateRecommendations_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconGenerate}" Fill="White" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock x:Name="GenerateRecBtnText" Text="Generate AI Recommendations" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Not-configured state -->
                                            <Border x:Name="AiRecNotConfigured" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="Research AI service is not configured yet" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" FontSize="13.5"/>
                                                    <TextBlock Text="Connect a Research AI backend endpoint in Settings to generate recommendations inside the app."
                                                               Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,6,0,10"/>
                                                    <Button Content="Open Research AI settings" Style="{StaticResource SoftButton}" HorizontalAlignment="Left" Click="OpenResearchAiSettings_Click"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Error state (first-time generation failed — nothing to lose) -->
                                            <Border x:Name="AiRecError" Background="{StaticResource DangerSoftBrush}" CornerRadius="10" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock x:Name="AiRecErrorText" Foreground="{StaticResource DangerBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <Button Content="Retry" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="GenerateRecommendations_Click"/>
                                                        <Button Content="Open Research AI Settings" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="OpenResearchAiSettings_Click"/>
                                                        <Button Content="Open details" Style="{StaticResource GhostButton}" Click="ShowAiDiagnostics_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Regeneration-failed, non-destructive state (previous recommendations kept and still shown below) -->
                                            <Border x:Name="AiRecRegenFailedBanner" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="16" Margin="0,14,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock x:Name="AiRecRegenFailedText" Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <Button Content="Retry" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="RetryRegenerateRecommendations_Click"/>
                                                        <Button Content="Open Research AI Settings" Style="{StaticResource SoftButton}" Margin="0,0,10,0" Click="OpenResearchAiSettings_Click"/>
                                                        <Button Content="Open details" Style="{StaticResource GhostButton}" Click="ShowAiDiagnostics_Click"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- D. Recommendations viewer -->
                                    <Border x:Name="AiRecEmptyHint" Style="{StaticResource SoftCardBorder}" Padding="28" Margin="0,0,0,16">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="No recommendations yet" Foreground="{StaticResource TextBrush}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Click Generate AI Recommendations to create structured guidance for this project."
                                                       Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="AiRecViewer" Style="{StaticResource CardBorder}" Padding="26" Margin="0,0,0,16" Visibility="Collapsed">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="Recommendations" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                                <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="8" Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock x:Name="AiRecSourceBadge" Text="Imported" Foreground="{StaticResource PrimaryBrush}" FontSize="11.5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel x:Name="RecTitleSec" Margin="0,14,0,0">
                                                <TextBlock Text="Refined research title" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="RecRefinedTitle" Foreground="{StaticResource TextBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecStudyDesignSec" Margin="0,14,0,0">
                                                <TextBlock Text="Recommended study design" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="RecStudyDesign" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecQuestionSec" Margin="0,14,0,0">
                                                <TextBlock Text="Research question" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="RecQuestion" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecPrimarySec" Margin="0,14,0,0">
                                                <TextBlock Text="Primary objective" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,5"/>
                                                <TextBlock x:Name="RecPrimaryObjective" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecSecondarySec" Margin="0,16,0,0">
                                                <TextBlock Text="Secondary objectives" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecSecondaryList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecVariablesSec" Margin="0,16,0,0">
                                                <TextBlock Text="Suggested variables" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecVariablesList" ItemTemplate="{StaticResource ResearchVariableTemplate}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecAnalysesSec" Margin="0,6,0,0">
                                                <TextBlock Text="Suggested analyses" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecAnalysesList" ItemTemplate="{StaticResource ResearchAnalysisTemplate}"/>
                                            </StackPanel>
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel x:Name="RecInclusionSec" Grid.Column="0">
                                                    <TextBlock Text="Inclusion criteria" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                    <ItemsControl x:Name="RecInclusionList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                                </StackPanel>
                                                <StackPanel x:Name="RecExclusionSec" Grid.Column="2">
                                                    <TextBlock Text="Exclusion criteria" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                    <ItemsControl x:Name="RecExclusionList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel x:Name="RecDataCollectionSec" Margin="0,16,0,0">
                                                <TextBlock Text="Data-collection suggestions" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecDataCollectionList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecBiasSec" Margin="0,16,0,0">
                                                <TextBlock Text="Bias &amp; limitations" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecBiasList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecEthicsSec" Margin="0,16,0,0">
                                                <TextBlock Text="Ethics notes" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecEthicsList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                            </StackPanel>
                                            <StackPanel x:Name="RecNextStepsSec" Margin="0,16,0,0">
                                                <TextBlock Text="Next steps" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="RecNextStepsList" ItemTemplate="{StaticResource ResearchBulletTemplate}"/>
                                            </StackPanel>

                                            <Border x:Name="RecRawCard" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,16,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="AI response (unstructured)" Foreground="{StaticResource SoftMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                                                    <TextBox x:Name="RecRawText" Style="{StaticResource EditorTextBox}" MinHeight="120" MaxHeight="260"
                                                             IsReadOnly="True" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <Border x:Name="AiRecAcceptRow" Background="{StaticResource PrimarySoftBrush}" CornerRadius="10" Padding="16" Margin="0,20,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Happy with these? Accept them to build your editable research plan below."
                                                               Foreground="{StaticResource PrimaryBrush}" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                                    <Button Grid.Column="1" x:Name="AcceptRecBtn" Content="Accept Recommendations Into Plan"
                                                            Style="{StaticResource PremiumButton}" VerticalAlignment="Center" Click="AcceptRecommendations_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- Accepted status (Phase 3 polish) -->
                                            <Border x:Name="AiRecAcceptedBanner" Background="{StaticResource SuccessSoftBrush}" CornerRadius="10" Padding="16" Margin="0,20,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource SuccessBrush}" CornerRadius="12" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="Accepted" Foreground="White" FontSize="11.5" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Recommendations accepted. Your research plan is ready."
                                                               Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <Border x:Name="AiRecNeedsReviewBanner" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="16" Margin="0,20,0,0" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource WarningBrush}" CornerRadius="12" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                                                        <TextBlock Text="Needs review" Foreground="White" FontSize="11.5" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="Project details changed after recommendations were accepted. Review or regenerate recommendations before continuing."
                                                               Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="560"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- 4. Research Plan Summary -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="Research Plan Summary" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Your editable plan. Edit freely — nothing here is overwritten automatically." Style="{StaticResource Caption}" Margin="0,4,0,0"/>

                                            <Border x:Name="PlanEmptyHint" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}"
                                                    BorderThickness="1" CornerRadius="10" Padding="20" Margin="0,14,0,0">
                                                <TextBlock Text="Generate AI recommendations first, then accept them to build a structured research plan."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"/>
                                            </Border>

                                            <StackPanel x:Name="PlanEditor" Margin="0,16,0,0" Visibility="Collapsed">
                                                <TextBlock Text="Final title" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanTitle" Style="{StaticResource EditorTextBox}"/>
                                                <TextBlock Text="Research question" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanQuestion" Style="{StaticResource EditorTextBox}" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <Grid Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Study design" Style="{StaticResource RpFieldLabel}"/>
                                                        <TextBox x:Name="PlanDesign" Style="{StaticResource EditorTextBox}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Aim" Style="{StaticResource RpFieldLabel}"/>
                                                        <TextBox x:Name="PlanAim" Style="{StaticResource EditorTextBox}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="Primary objective" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanPrimaryObj" Style="{StaticResource EditorTextBox}" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <TextBlock Text="Secondary objectives (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanSecondaryObj" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <Grid Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Population" Style="{StaticResource RpFieldLabel}"/>
                                                        <TextBox x:Name="PlanPopulation" Style="{StaticResource EditorTextBox}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Setting" Style="{StaticResource RpFieldLabel}"/>
                                                        <TextBox x:Name="PlanSetting" Style="{StaticResource EditorTextBox}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="Inclusion criteria (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanInclusion" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <TextBlock Text="Exclusion criteria (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanExclusion" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <TextBlock Text="Main variables (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanVariables" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <TextBlock Text="Suggested analyses (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanAnalyses" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                                <TextBlock Text="Next steps (one per line)" Style="{StaticResource RpFieldLabel}"/>
                                                <TextBox x:Name="PlanNextSteps" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>

                                                <Button Content="Save Research Plan" Style="{StaticResource PremiumButton}" Width="180" HorizontalAlignment="Left" Margin="0,16,0,0" Click="SaveResearchPlan_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>

                                <!-- DATA EXTRACTION (Phase 3) -->
                                <StackPanel x:Name="TabDataExt" Visibility="Collapsed" VerticalAlignment="Top">
                                    <StackPanel.Resources>
                                        <Style x:Key="DxCellText" TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                        <Style x:Key="DxSumLabel" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                        <Style x:Key="DxSumValue" TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Header + status -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                                <Path Data="{StaticResource IconTable}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Data Extraction Sheet" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Create a structured variable sheet before uploading data or running statistics."
                                                           Style="{StaticResource Caption}" TextWrapping="Wrap" MaxWidth="560"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border x:Name="DxStatusChip" Grid.Column="1" VerticalAlignment="Center" Background="{StaticResource SoftCardBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="14,7">
                                            <TextBlock x:Name="DxStatusChipText" Text="Not started" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                        </Border>
                                    </Grid>

                                    <!-- SECTION A — Extraction Sheet: build & manage the variable sheet -->
                                    <Border Style="{StaticResource CardBorder}" Padding="22,18" Margin="0,0,0,16">
                                        <Border.Resources>
                                            <Style x:Key="DxGroupLabel" TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="10.5"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="{StaticResource SoftMutedBrush}"/>
                                                <Setter Property="Margin" Value="2,0,0,8"/>
                                            </Style>
                                            <!-- Uniform button sizing so groups line up and wrap cleanly -->
                                            <Style x:Key="DxActionPrimary" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
                                                <Setter Property="Height" Value="42"/>
                                                <Setter Property="MinWidth" Value="158"/>
                                                <Setter Property="Margin" Value="0,0,10,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                            <Style x:Key="DxActionSoft" TargetType="Button" BasedOn="{StaticResource SoftButton}">
                                                <Setter Property="Height" Value="42"/>
                                                <Setter Property="MinWidth" Value="158"/>
                                                <Setter Property="Margin" Value="0,0,10,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            </Style>
                                        </Border.Resources>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconGrid}" Fill="{StaticResource PrimaryBrush}" Width="17" Height="17" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                <TextBlock Text="Extraction Sheet" Style="{StaticResource SectionHeader}" FontSize="16" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Each row is one variable you plan to collect. Build the sheet from your research plan, proposal, questionnaire, or form."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" MaxWidth="680" Margin="0,4,0,14"/>

                                            <!-- BUILD -->
                                            <TextBlock Text="BUILD" Style="{StaticResource DxGroupLabel}"/>
                                            <WrapPanel>
                                                <Button x:Name="DxGenerateAiBtn" Style="{StaticResource DxActionPrimary}" Click="GenerateExtractionSheet_Click"
                                                        ToolTip="Let Research AI build the sheet from your research plan, proposal variable sections, and questions"
                                                        ToolTipService.ShowOnDisabled="True">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconGenerate}" Fill="White" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Generate by AI" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DxActionSoft}" Click="AddVariable_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconPlus}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Add Variable" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DxActionSoft}" Click="OpenPasteQuestions_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconEdit}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Paste Questions" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DxActionSoft}" Click="OpenGoogleForm_Click" Margin="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconLink}" Fill="{StaticResource PrimaryBrush}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Google Form Link" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>

                                            <Border Height="1" Background="{StaticResource BorderBrushSoft}" Margin="0,16"/>

                                            <!-- MANAGE -->
                                            <TextBlock Text="MANAGE" Style="{StaticResource DxGroupLabel}"/>
                                            <WrapPanel>
                                                <Button Style="{StaticResource DxActionSoft}" Click="ValidateSheet_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconCheck}" Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Validate Sheet" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource DxActionSoft}" Click="ClearSheet_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconTrash}" Fill="{StaticResource DangerBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Clear Sheet" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="DxUndoBtn" Style="{StaticResource DxActionSoft}" MinWidth="96" IsEnabled="False" Click="UndoSheet_Click" ToolTip="Undo the last sheet change (this session)">
                                                    <TextBlock Text="Undo" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button x:Name="DxRedoBtn" Style="{StaticResource DxActionSoft}" MinWidth="96" IsEnabled="False" Click="RedoSheet_Click" ToolTip="Redo the last undone change">
                                                    <TextBlock Text="Redo" VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource DxActionPrimary}" Click="SaveExtractionSheet_Click" Margin="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconCheck}" Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Editable spreadsheet (part of SECTION A) -->
                                    <Border Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid Margin="18,16,18,12">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Variables" Style="{StaticResource SectionHeader}"/>
                                                    <TextBlock Text="Every row is one field you plan to collect. Edit any cell; use the row actions to reorder, duplicate, edit, or delete."
                                                               Style="{StaticResource Caption}" TextWrapping="Wrap" MaxWidth="640"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" VerticalAlignment="Center" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Padding="12,6">
                                                    <TextBlock x:Name="DxVarCountText" Text="0 variables" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                </Border>
                                            </Grid>

                                            <Grid>
                                                <DataGrid x:Name="DxGrid" Style="{StaticResource ResearchDataGrid}" MaxHeight="430" Margin="0,0,0,0"
                                                          BorderThickness="0,1,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                          BeginningEdit="DxGrid_BeginningEdit" CellEditEnding="DxGrid_CellEditEnding">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Variable name" Binding="{Binding VariableName}" Width="125">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource DxCellText}"><Setter Property="FontWeight" Value="SemiBold"/></Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Question label" Binding="{Binding QuestionLabel}" Width="175" ElementStyle="{StaticResource DxCellText}"/>
                                                        <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding VariableType}" ItemsSource="{x:Static local:ResearchVariableOptions.VariableTypes}" Width="100"/>
                                                        <DataGridComboBoxColumn Header="Level" SelectedItemBinding="{Binding MeasurementLevel}" ItemsSource="{x:Static local:ResearchVariableOptions.MeasurementLevels}" Width="95"/>
                                                        <DataGridComboBoxColumn Header="Role" SelectedItemBinding="{Binding Role}" ItemsSource="{x:Static local:ResearchVariableOptions.Roles}" Width="105"/>
                                                        <DataGridTextColumn Header="Coding / value labels" Binding="{Binding Coding}" Width="135" ElementStyle="{StaticResource DxCellText}"/>
                                                        <DataGridTextColumn Header="Missing rule" Binding="{Binding MissingValueRule}" Width="95" ElementStyle="{StaticResource DxCellText}"/>
                                                        <DataGridComboBoxColumn Header="Source" SelectedItemBinding="{Binding Source}" ItemsSource="{x:Static local:ResearchVariableOptions.Sources}" Width="125"/>
                                                        <DataGridCheckBoxColumn Header="Req." Binding="{Binding IsRequired}" Width="46"/>
                                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="125" ElementStyle="{StaticResource DxCellText}"/>
                                                        <DataGridTemplateColumn Header="Actions" Width="150" CanUserSort="False">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <Button Style="{StaticResource GridActionButton}" Click="MoveVariableUp_Click" ToolTip="Move up">
                                                                            <Path Data="{StaticResource IconArrowUp}" Fill="{StaticResource MutedBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                                        </Button>
                                                                        <Button Style="{StaticResource GridActionButton}" Click="MoveVariableDown_Click" ToolTip="Move down">
                                                                            <Path Data="{StaticResource IconArrowDown}" Fill="{StaticResource MutedBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                                        </Button>
                                                                        <Button Style="{StaticResource GridActionButton}" Click="EditVariable_Click" ToolTip="Edit details">
                                                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                                        </Button>
                                                                        <Button Style="{StaticResource GridActionButton}" Click="DuplicateVariable_Click" ToolTip="Duplicate">
                                                                            <Path Data="{StaticResource IconCopy}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                                        </Button>
                                                                        <Button Style="{StaticResource GridActionButton}" Click="DeleteVariable_Click" ToolTip="Delete">
                                                                            <Path Data="{StaticResource IconTrash}" Fill="{StaticResource DangerBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                                        </Button>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>

                                                <!-- Empty state -->
                                                <StackPanel x:Name="DxEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24,40" IsHitTestVisible="False">
                                                    <Path Data="{StaticResource IconGrid}" Fill="{StaticResource BorderBrushSoft}" Width="42" Height="42" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="No variables yet" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                                    <TextBlock Text="Generate by AI, add a variable, or import from your proposal / CSV to begin."
                                                               FontSize="13" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360" TextAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- SECTION B — Data Samples: upload & compare collected sample data -->
                                    <Border x:Name="DxSamplesCard" Style="{StaticResource CardBorder}" Padding="22" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconImport}" Fill="{StaticResource PrimaryBrush}" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock Text="Data Samples" Style="{StaticResource SectionHeader}" FontSize="16" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Upload CSV sample data here. The app will compare CSV columns with your extraction sheet. Statistics will be calculated in a later phase."
                                                               Style="{StaticResource Caption}" TextWrapping="Wrap" MaxWidth="620" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <Border x:Name="DxSamplesFormBadge" Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Padding="12,6" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconLink}" Fill="{StaticResource PrimaryBrush}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Google Form linked" FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <WrapPanel Margin="0,16,0,0">
                                                <Button Style="{StaticResource SoftButton}" Click="ImportCsv_Click" Margin="0,0,10,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconImport}" Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Import CSV Sample" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="DxViewCsvBtn" Style="{StaticResource SoftButton}" Content="View CSV Summary" Margin="0,0,10,8" Click="ViewCsvSummary_Click"/>
                                                <Button x:Name="DxClearSampleBtn" Style="{StaticResource GhostButton}" Content="Clear Sample" Margin="0,0,0,8" Click="ClearSample_Click"/>
                                            </WrapPanel>

                                            <!-- Empty state -->
                                            <Border x:Name="DxSamplesEmpty" Background="{StaticResource SoftCardBrush}" CornerRadius="10" Padding="16,14" Margin="0,6,0,0">
                                                <TextBlock Text="No sample uploaded yet. Import a CSV to detect columns and compare them against your extraction sheet."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- Uploaded info -->
                                            <StackPanel x:Name="DxSamplesInfo" Visibility="Collapsed" Margin="0,6,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="File" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampFile" Grid.Column="1" Text="—" Style="{StaticResource DxSumValue}" TextTrimming="CharacterEllipsis" MaxWidth="220"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Total rows / samples" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampRows" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Detected columns" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampCols" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Matched variables" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampMatched" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="CSV columns not in sheet" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampCsvOnly" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Sheet variables not in CSV" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampSheetOnly" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Target sample size" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampTarget" Grid.Column="1" Text="—" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Remaining samples needed" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampRemaining" Grid.Column="1" Text="—" Style="{StaticResource DxSumValue}"/></Grid>
                                                        <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="Sample status" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSampStatus" Grid.Column="1" Text="—" Style="{StaticResource DxSumValue}"/></Grid>
                                                    </StackPanel>
                                                </Grid>
                                                <Border x:Name="DxSampWarn" Background="{StaticResource WarningSoftBrush}" CornerRadius="9" Padding="13,10" Margin="0,12,0,0" Visibility="Collapsed">
                                                    <StackPanel>
                                                        <TextBlock x:Name="DxSampWarnText" Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                        <Button x:Name="DxUploadCompleteBtn" Content="Upload Complete CSV" Style="{StaticResource SoftButton}" HorizontalAlignment="Left" Margin="0,10,0,0" Visibility="Collapsed" Click="ImportCsv_Click"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Data dictionary summary + Validation -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="330"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Data dictionary summary -->
                                        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="22" VerticalAlignment="Top">
                                            <StackPanel>
                                                <TextBlock Text="Data dictionary summary" Style="{StaticResource SectionHeader}" FontSize="15"/>
                                                <TextBlock Text="A quick count of what your sheet covers." Style="{StaticResource Caption}" Margin="0,2,0,14"/>
                                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Total variables" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumTotal" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Border Height="1" Background="{StaticResource BorderBrushSoft}" Margin="0,9"/>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Outcomes" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumOutcome" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Exposures / predictors" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumExposure" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Confounders" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumConfounder" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Demographics" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumDemographic" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Identifiers" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumIdentifier" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Required fields" Style="{StaticResource DxSumLabel}"/><TextBlock x:Name="DxSumRequired" Grid.Column="1" Text="0" Style="{StaticResource DxSumValue}"/></Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Validation report -->
                                        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="22" VerticalAlignment="Top">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <TextBlock Text="Validation report" Style="{StaticResource SectionHeader}" FontSize="15" VerticalAlignment="Center"/>
                                                    <Border x:Name="DxValStatusPill" Grid.Column="1" Background="{StaticResource SoftCardBrush}" CornerRadius="16" Padding="12,6" VerticalAlignment="Center">
                                                        <TextBlock x:Name="DxValStatusText" Text="Not checked" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                    </Border>
                                                </Grid>

                                                <TextBlock x:Name="DxValEmpty" Text="Run “Validate Sheet” to check for duplicate names, missing types, coding gaps, CSV mismatches, and more."
                                                           Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                                <!-- Errors -->
                                                <StackPanel x:Name="DxErrorsSection" Visibility="Collapsed" Margin="0,14,0,0">
                                                    <TextBlock x:Name="DxErrorsHeader" Text="Errors" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,0,0,6"/>
                                                    <ItemsControl x:Name="DxErrorsList">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource DangerSoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource DangerBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Warnings -->
                                                <StackPanel x:Name="DxWarningsSection" Visibility="Collapsed" Margin="0,10,0,0">
                                                    <TextBlock x:Name="DxWarningsHeader" Text="Warnings" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,0,0,6"/>
                                                    <ItemsControl x:Name="DxWarningsList">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Suggestions -->
                                                <StackPanel x:Name="DxSuggestionsSection" Visibility="Collapsed" Margin="0,10,0,0">
                                                    <TextBlock x:Name="DxSuggestionsHeader" Text="Suggestions" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource InfoBrush}" Margin="0,0,0,6"/>
                                                    <ItemsControl x:Name="DxSuggestionsList">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource InfoSoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <!-- Conflicts entry point -->
                                                <Button x:Name="DxResolveConflictsBtn" Style="{StaticResource SoftButton}" HorizontalAlignment="Left" Margin="0,14,0,0" MinWidth="180" Visibility="Collapsed" Click="OpenConflicts_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconWarn}" Fill="{StaticResource PrimaryBrush}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Resolve Conflicts" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- Ready banner -->
                                                <Border x:Name="DxReadyBanner" Background="{StaticResource SuccessSoftBrush}" CornerRadius="10" Padding="14,12" Margin="0,14,0,0" Visibility="Collapsed">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconCheck}" Fill="{StaticResource SuccessBrush}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock x:Name="DxReadyBannerText" Text="Your extraction sheet is ready for the next phase." Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <!-- STATISTICS (Phase 4A descriptive + Phase 4B Part 1 recommended analysis) -->
                                <StackPanel x:Name="TabStats" Visibility="Collapsed" VerticalAlignment="Top" MaxWidth="1020" HorizontalAlignment="Left">

                                    <!-- Internal switch: Descriptive Statistics | Recommended Analysis | Computed Results -->
                                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="10" Padding="4" HorizontalAlignment="Left" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="StSegDescriptive" Style="{StaticResource SegTabActive}" Content="Descriptive Statistics" Click="StShowDescriptive_Click"/>
                                            <Button x:Name="StSegRecommended" Style="{StaticResource SegTab}" Content="Recommended Analysis" Margin="4,0,0,0" Click="StShowRecommended_Click"/>
                                            <Button x:Name="StSegComputed" Style="{StaticResource SegTab}" Content="Computed Results" Margin="4,0,0,0" Click="StShowComputed_Click"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ============ DESCRIPTIVE STATISTICS (Phase 4A) ============ -->
                                    <StackPanel x:Name="StDescriptiveView">

                                    <!-- Statistics Readiness dashboard -->
                                    <Border Style="{StaticResource CardBorder}" Padding="26">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Statistics Readiness" Style="{StaticResource SectionHeader}"/>
                                                    <TextBlock Text="Deterministic descriptive analysis based on your extraction sheet and dataset. The extraction sheet decides how each variable is analyzed."
                                                               Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="620"/>
                                                </StackPanel>
                                                <Border x:Name="StStateBadge" Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource SoftCardBrush}" CornerRadius="16" Padding="14,7">
                                                    <TextBlock x:Name="StStateBadgeText" Text="Checking…" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                                </Border>
                                            </Grid>

                                            <!-- Analysis Readiness score -->
                                            <Grid Margin="0,18,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Analysis Readiness" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="StScoreText" Grid.Column="1" Text="—" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                            </Grid>
                                            <Border Background="{StaticResource SoftCardBrush}" CornerRadius="4" Height="8" Margin="0,6,0,0">
                                                <Border x:Name="StScoreBar" Background="{StaticResource PrimaryBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                                            </Border>
                                            <TextBlock x:Name="StExplanationText" FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>

                                            <!-- Readiness cards -->
                                            <ItemsControl x:Name="StCardsList" Margin="0,16,0,0">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="0" Margin="0,0,10,10" MinWidth="150">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                <Border x:Name="CardAccent" Width="3" Background="{StaticResource MutedBrush}" CornerRadius="2" Margin="0,8,0,8"/>
                                                                <StackPanel Grid.Column="1" Margin="11,9,14,9">
                                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                    <TextBlock x:Name="CardValue" Text="{Binding Value}" FontSize="12.5" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,3,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Good">
                                                                <Setter TargetName="CardAccent" Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                                <Setter TargetName="CardValue" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Warn">
                                                                <Setter TargetName="CardAccent" Property="Background" Value="{StaticResource WarningBrush}"/>
                                                                <Setter TargetName="CardValue" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Bad">
                                                                <Setter TargetName="CardAccent" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                                <Setter TargetName="CardValue" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Actions -->
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button x:Name="StRunBtn" Style="{StaticResource PremiumButton}" Content="Run Descriptive Statistics" MinWidth="220" Margin="0,0,10,6"
                                                        ToolTipService.ShowOnDisabled="True" Click="RunDescriptiveStatistics_Click"/>
                                                <Button x:Name="StPrimaryActionBtn" Style="{StaticResource SoftButton}" Content="Upload CSV" MinWidth="160" Margin="0,0,10,6" Visibility="Collapsed" Click="StPrimaryAction_Click"/>
                                                <Button x:Name="StMagicFixBtn" Style="{StaticResource SoftButton}" Content="Magic Fix" MinWidth="130" Margin="0,0,10,6" Visibility="Collapsed"
                                                        ToolTipService.ShowOnDisabled="True" ToolTip="Suggest safe repairs for variable types, coding, and value labels before running statistics." Click="MagicFix_Click"/>
                                                <Button x:Name="StReviewWarningsBtn" Style="{StaticResource SoftButton}" Content="Review Warnings" MinWidth="150" Margin="0,0,10,6" Visibility="Collapsed" Click="StReviewWarnings_Click"/>
                                            </WrapPanel>

                                            <!-- Readiness checks detail (expandable) -->
                                            <StackPanel x:Name="StIssuesSection" Visibility="Collapsed" Margin="0,14,0,0">
                                                <TextBlock Text="Readiness checks" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                                <ItemsControl x:Name="StIssuesList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="IssueBorder" Background="{StaticResource InfoSoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,0,0,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                    <Border x:Name="IssueChip" Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="8,2" VerticalAlignment="Top" Margin="0,1,10,0">
                                                                        <TextBlock x:Name="IssueChipText" Text="{Binding SeverityDisplay}" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="12.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding SeverityDisplay}" Value="Blocker">
                                                                    <Setter TargetName="IssueBorder" Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                                    <Setter TargetName="IssueChipText" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding SeverityDisplay}" Value="Warning">
                                                                    <Setter TargetName="IssueBorder" Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                                                    <Setter TargetName="IssueChipText" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Stale results notice -->
                                    <Border x:Name="StStaleBanner" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="14,12" Margin="0,14,0,0" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Dataset or extraction sheet changed. Rerun descriptive statistics to update results."
                                                       Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Style="{StaticResource SoftButton}" Content="Rerun Analysis" MinWidth="130" Margin="12,0,0,0" Click="RunDescriptiveStatistics_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- Dataset Overview -->
                                    <Border x:Name="StDatasetCard" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Dataset Overview" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                            <TextBlock x:Name="StDatasetSubText" Style="{StaticResource Caption}" Margin="0,4,0,10" TextWrapping="Wrap"/>
                                            <ItemsControl x:Name="StOverviewList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,7">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                                            <TextBlock x:Name="OvValue" Grid.Column="1" Text="{Binding Value}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Warn"><Setter TargetName="OvValue" Property="Foreground" Value="{StaticResource WarningBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Bad"><Setter TargetName="OvValue" Property="Foreground" Value="{StaticResource DangerBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Good"><Setter TargetName="OvValue" Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Variable Matching Summary -->
                                    <Border x:Name="StMatchingCard" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0" Visibility="Collapsed">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Variable Matching Summary" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                                    <TextBlock Text="How dataset columns map to your extraction sheet variables." Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <Button x:Name="StGoToConflictsBtn" Grid.Column="1" Style="{StaticResource SoftButton}" Content="Go to Resolve Conflicts" MinWidth="180" VerticalAlignment="Top" Visibility="Collapsed" Click="StGoToConflicts_Click"/>
                                            </Grid>
                                            <ItemsControl x:Name="StMatchingList" Margin="0,12,0,0">
                                                <ItemsControl.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="12,7" Margin="0,4,0,8">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource TextBrush}"/>
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ItemsControl.GroupStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="4,7,4,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2.2*"/><ColumnDefinition Width="1.6*"/><ColumnDefinition Width="1.6*"/><ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Label}" FontSize="11.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding TypeDisplay}" FontSize="11.5" Foreground="{StaticResource TextBrush}"/>
                                                                    <TextBlock Text="{Binding Role}" FontSize="11.5" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding ColumnDisplay}" FontSize="11.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding CountsDisplay}" FontSize="11.5" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                                <Border x:Name="MatchChip" Grid.Column="3" Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="9,3" VerticalAlignment="Top" Margin="8,0,0,0">
                                                                    <TextBlock x:Name="MatchChipText" Text="{Binding StatusText}" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource MutedBrush}"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Good">
                                                                <Setter TargetName="MatchChip" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                                <Setter TargetName="MatchChipText" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Warn">
                                                                <Setter TargetName="MatchChip" Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                                                <Setter TargetName="MatchChipText" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StatusKind}" Value="Bad">
                                                                <Setter TargetName="MatchChip" Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                                <Setter TargetName="MatchChipText" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Professional Output options -->
                                    <Border x:Name="StOptionsCard" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Text="Professional Output" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                            <TextBlock Text="Output formatting for the generated tables. Full precision is kept internally; these options only change how results are displayed and exported."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                            <WrapPanel>
                                                <StackPanel Margin="0,0,22,10">
                                                    <TextBlock Text="Decimal places" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5"/>
                                                    <ComboBox x:Name="StDecimalsBox" Width="90" SelectionChanged="StOutputOption_Changed"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,22,10">
                                                    <TextBlock Text="Table style" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5"/>
                                                    <ComboBox x:Name="StStyleBox" Width="190" SelectionChanged="StOutputOption_Changed"/>
                                                </StackPanel>
                                            </WrapPanel>
                                            <WrapPanel Margin="0,2,0,0">
                                                <CheckBox x:Name="StOptMissing" Content="Include missing values summary" IsChecked="True" Margin="0,0,20,8" Checked="StOutputOption_Changed" Unchecked="StOutputOption_Changed"/>
                                                <CheckBox x:Name="StOptAudit" Content="Include audit notes" IsChecked="True" Margin="0,0,20,8" Checked="StOutputOption_Changed" Unchecked="StOutputOption_Changed"/>
                                                <CheckBox x:Name="StOptIgnored" Content="Note ignored dataset columns" IsChecked="True" Margin="0,0,20,8" Checked="StOutputOption_Changed" Unchecked="StOutputOption_Changed"/>
                                                <CheckBox x:Name="StOptText" Content="Include text variable summary" IsChecked="True" Margin="0,0,20,8" Checked="StOutputOption_Changed" Unchecked="StOutputOption_Changed"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Output -->
                                    <StackPanel x:Name="StOutputPanel" Visibility="Collapsed" Margin="0,14,0,0">
                                        <Border Style="{StaticResource CardBorder}" Padding="26">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Descriptive Statistics" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                                        <TextBlock x:Name="StOutputMetaText" Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource SuccessSoftBrush}" CornerRadius="14" Padding="11,5">
                                                        <TextBlock Text="Deterministic calculations" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                                    </Border>
                                                </Grid>
                                                <WrapPanel Margin="0,14,0,0">
                                                    <Button Style="{StaticResource SoftButton}" Content="Copy All Results" MinWidth="140" Margin="0,0,10,6" Click="StCopyAll_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Export Tables (CSV)" MinWidth="150" Margin="0,0,10,6" Click="StExportCsv_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Export Audit Notes (TXT)" MinWidth="170" Margin="0,0,10,6" Click="StExportAudit_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Export HTML Report" MinWidth="150" Margin="0,0,10,6" Click="StExportHtml_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel x:Name="StOutputHost"/>
                                    </StackPanel>
                                    </StackPanel>
                                    <!-- ============ END DESCRIPTIVE STATISTICS ============ -->

                                    <!-- ============ RECOMMENDED ANALYSIS (Phase 4B Part 1) ============ -->
                                    <StackPanel x:Name="StRecommendedView" Visibility="Collapsed">

                                        <!-- Header -->
                                        <Border Style="{StaticResource CardBorder}" Padding="26">
                                            <StackPanel>
                                                <TextBlock Text="Recommended Analysis" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Deterministic statistical test planning based on your Extraction Sheet and dataset structure."
                                                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,10" MaxWidth="640"/>
                                                <Border Background="{StaticResource InfoSoftBrush}" CornerRadius="8" Padding="12,9">
                                                    <TextBlock Text="Recommendations are planning-only until you click Run. Supported analyses are computed locally using deterministic C# only."
                                                               Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- LOCKED state -->
                                        <Border x:Name="StRecoLockedCard" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0" Visibility="Collapsed">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="40" Height="40" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Margin="0,0,12,0">
                                                        <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Recommended Analysis locked" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock Text="Complete Descriptive Statistics readiness first." Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock x:Name="StRecoLockedReason" FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,14,0,0"/>
                                                <TextBlock Text="Recommended Analysis uses your validated extraction sheet, matched dataset, and Phase 4A readiness checks to avoid incorrect statistical test suggestions."
                                                           FontSize="12.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,12"/>
                                                <ItemsControl x:Name="StRecoChecklist">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                                <TextBlock x:Name="ChkGlyph" Text="{Binding Glyph}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource MutedBrush}" Width="20"/>
                                                                <TextBlock Text="{Binding Label}" FontSize="12.5" Foreground="{StaticResource TextBrush}"/>
                                                            </StackPanel>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Good"><Setter TargetName="ChkGlyph" Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="Bad"><Setter TargetName="ChkGlyph" Property="Foreground" Value="{StaticResource DangerBrush}"/></DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <WrapPanel Margin="0,14,0,0">
                                                    <Button Style="{StaticResource PremiumButton}" Content="Go to Descriptive Statistics" MinWidth="210" Margin="0,0,10,6" Click="StRecoGoDescriptive_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Run Magic Fix" MinWidth="130" Margin="0,0,10,6" Click="StRecoRunMagicFix_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Go to Data Extraction" MinWidth="170" Margin="0,0,10,6" Click="StRecoGoDataExtraction_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Upload Complete CSV" MinWidth="170" Margin="0,0,10,6" Click="StRecoUploadCsv_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- UNLOCKED state -->
                                        <StackPanel x:Name="StRecoUnlocked" Visibility="Collapsed">

                                            <!-- Ready-with-warnings banner -->
                                            <Border x:Name="StRecoWarnBanner" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="14,11" Margin="0,14,0,0" Visibility="Collapsed">
                                                <TextBlock Text="Recommended Analysis is available, but warnings should be reviewed before using these suggestions."
                                                           Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- Summary cards -->
                                            <Border Style="{StaticResource CardBorder}" Padding="22" Margin="0,14,0,0">
                                                <StackPanel>
                                                    <TextBlock x:Name="StRecoOutcomeText" FontSize="13.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                    <ItemsControl x:Name="StRecoSummaryCards" Margin="0,12,0,0">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,10,10" MinWidth="150">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        <TextBlock x:Name="SumVal" Text="{Binding Value}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,3,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Good"><Setter TargetName="SumVal" Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Warn"><Setter TargetName="SumVal" Property="Foreground" Value="{StaticResource WarningBrush}"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Bad"><Setter TargetName="SumVal" Property="Foreground" Value="{StaticResource DangerBrush}"/></DataTrigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="Supported analyses only" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,4"/>
                                                    <WrapPanel Margin="0,0,0,0">
                                                        <Button Style="{StaticResource PremiumButton}" Content="Run all supported analyses" MinWidth="220" Margin="0,0,10,6" Click="StRecoRunAll_Click"/>
                                                        <Button Style="{StaticResource SoftButton}" Content="Refresh Recommendations" MinWidth="190" Margin="0,0,10,6" Click="StRecoRefresh_Click"/>
                                                        <Button Style="{StaticResource SoftButton}" Content="Copy Recommendations" MinWidth="180" Margin="0,0,10,6" Click="StRecoCopy_Click"/>
                                                        <Button Style="{StaticResource SoftButton}" Content="Export TXT" MinWidth="110" Margin="0,0,10,6" Click="StRecoExportTxt_Click"/>
                                                        <Button Style="{StaticResource SoftButton}" Content="Export CSV" MinWidth="110" Margin="0,0,10,6" Click="StRecoExportCsv_Click"/>
                                                        <Button Style="{StaticResource GhostButton}" Content="Go to Descriptive Statistics" MinWidth="200" Margin="0,0,10,6" Click="StRecoGoDescriptive_Click"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Recommendation cards, grouped by status -->
                                            <ItemsControl x:Name="StRecoList" Margin="0,4,0,0">
                                                <ItemsControl.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="12,7" Margin="0,16,0,4">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource MutedBrush}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ItemsControl.GroupStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,10,0,0">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding PredictorDisplay}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                        <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" TextWrapping="Wrap">
                                                                            <Run Text="{Binding PairTypeDisplay}"/><Run Text="   ·   Role: "/><Run Text="{Binding PredictorRole}"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <Border x:Name="StatusChip" Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource SoftCardBrush}" CornerRadius="12" Padding="10,4">
                                                                        <TextBlock x:Name="StatusChipText" Text="{Binding StatusDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                    </Border>
                                                                </Grid>

                                                                <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,12,0,0">
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding PlanningLabel}" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        <TextBlock Text="{Binding TestDisplay}" FontSize="13.5" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                </Border>

                                                                <TextBlock Text="{Binding Rationale}" FontSize="12.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                                                <Grid Margin="0,10,0,0">
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="Observed structure" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        <TextBlock FontSize="11.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,0,0">
                                                                            <Run Text="Outcome groups: "/><Run Text="{Binding OutcomeGroups}"/><Run Text="  ·  Predictor groups: "/><Run Text="{Binding PredictorGroups}"/>
                                                                        </TextBlock>
                                                                        <TextBlock FontSize="11.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap">
                                                                            <Run Text="Valid N — outcome "/><Run Text="{Binding OutcomeValidN}"/><Run Text=" (missing "/><Run Text="{Binding OutcomeMissingN}"/><Run Text="), predictor "/><Run Text="{Binding PredictorValidN}"/><Run Text=" (missing "/><Run Text="{Binding PredictorMissingN}"/><Run Text=")"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="Assumptions / checklist" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        <ItemsControl ItemsSource="{Binding Checklist}" Margin="0,2,0,0">
                                                                            <ItemsControl.ItemTemplate><DataTemplate>
                                                                                <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                                            </DataTemplate></ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding Notes}" Margin="0,10,0,0">
                                                                    <ItemsControl.ItemTemplate><DataTemplate>
                                                                        <TextBlock Text="{Binding}" FontSize="11.5" FontStyle="Italic" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                                    </DataTemplate></ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <!-- Phase 4B Part 2: run the recommended categorical test. Shown ONLY
                                                                     for eligible (Ready / Needs-assumption-review) categorical pairings. -->
                                                                <Button x:Name="RunInferenceBtn" Style="{StaticResource PremiumButton}" Content="Run this analysis"
                                                                        MinWidth="160" HorizontalAlignment="Left" Margin="0,14,0,0" Visibility="Collapsed"
                                                                        Click="StRecoRunInference_Click"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding CanComputeCategorical}" Value="True">
                                                                    <Setter TargetName="RunInferenceBtn" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CanComputeRank}" Value="True">
                                                                    <Setter TargetName="RunInferenceBtn" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding CanComputeSpearman}" Value="True">
                                                                    <Setter TargetName="RunInferenceBtn" Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="Good">
                                                                    <Setter TargetName="StatusChip" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                                    <Setter TargetName="StatusChipText" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="Warn">
                                                                    <Setter TargetName="StatusChip" Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                                                    <Setter TargetName="StatusChipText" Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusKind}" Value="Bad">
                                                                    <Setter TargetName="StatusChip" Property="Background" Value="{StaticResource DangerSoftBrush}"/>
                                                                    <Setter TargetName="StatusChipText" Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock x:Name="StRecoEmptyText" Visibility="Collapsed" FontSize="13" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- ============ END RECOMMENDED ANALYSIS ============ -->

                                    <!-- ============ COMPUTED RESULTS (Phase 4B Part 2) ============ -->
                                    <StackPanel x:Name="StComputedView" Visibility="Collapsed">

                                        <!-- Header -->
                                        <Border Style="{StaticResource CardBorder}" Padding="26">
                                            <StackPanel>
                                                <TextBlock Text="Computed Results" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Deterministic inferential analyses computed locally from your dataset."
                                                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,10" MaxWidth="640"/>
                                                <Border Background="{StaticResource InfoSoftBrush}" CornerRadius="8" Padding="12,9">
                                                    <TextBlock Text="Computed locally · deterministic · no AI. Aggregate outputs only — never individual participant rows."
                                                               Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                </Border>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Style="{StaticResource SoftButton}" Content="Export all TXT" MinWidth="130" Margin="0,0,10,0" Click="StComputedExportAllTxt_Click"/>
                                                    <Button Style="{StaticResource SoftButton}" Content="Export all CSV" MinWidth="130" Margin="0,0,10,0" Click="StComputedExportAllCsv_Click"/>
                                                    <Button Style="{StaticResource GhostButton}" Content="Clear results" MinWidth="110" Margin="0,0,10,0" Click="StComputedClear_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Loading state (shown while an analysis runs) -->
                                        <Border x:Name="StRunLoadingCard" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Running analysis" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock x:Name="StRunLoadingStep" Text="Preparing variables…" FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,12"/>
                                                <ProgressBar IsIndeterminate="True" Height="5" Background="{StaticResource SoftCardBrush}" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                                                <TextBlock Text="Computing locally — deterministic, no AI." FontSize="11.5" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Empty state -->
                                        <Border x:Name="StComputedEmpty" Style="{StaticResource CardBorder}" Padding="26" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="No analyses computed yet" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="Go to Recommended Analysis and click “Run this analysis” on a supported card to compute a result here."
                                                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                                <Button Style="{StaticResource PremiumButton}" Content="Go to Recommended Analysis" MinWidth="220" HorizontalAlignment="Left" Click="StShowRecommended_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Summary cards -->
                                        <Border x:Name="StComputedSummary" Style="{StaticResource CardBorder}" Padding="22" Margin="0,14,0,0" Visibility="Collapsed">
                                            <ItemsControl x:Name="StComputedSummaryCards">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,10,0" MinWidth="150">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                <TextBlock x:Name="CSumVal" Text="{Binding Value}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,3,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Good"><Setter TargetName="CSumVal" Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>

                                        <!-- Result cards -->
                                        <ItemsControl x:Name="StComputedList" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardBorder}" Padding="20" Margin="0,10,0,0">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding TestName}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Variables}" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                                <Border x:Name="CSigChip" Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource SoftCardBrush}" CornerRadius="12" Padding="10,4">
                                                                    <TextBlock x:Name="CSigText" Text="{Binding SignificanceText}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                </Border>
                                                            </Grid>

                                                            <WrapPanel Margin="0,12,0,0">
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="{Binding ValidNDisplay}" FontSize="12" Foreground="{StaticResource TextBrush}"/></Border>
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="{Binding PValueDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/></Border>
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="{Binding EffectDisplay}" FontSize="12" Foreground="{StaticResource TextBrush}"/></Border>
                                                            </WrapPanel>

                                                            <StackPanel Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding ComputedTimeDisplay}" FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                                                <Border Background="{StaticResource SuccessSoftBrush}" CornerRadius="6" Padding="8,3" Margin="0,4,0,0" HorizontalAlignment="Left">
                                                                    <TextBlock Text="Deterministic · No AI" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <WrapPanel Margin="0,12,0,0">
                                                                <Button Style="{StaticResource PremiumButton}" Content="View details" MinWidth="120" Margin="0,0,10,6" Click="StComputedViewDetails_Click"/>
                                                                <Button Style="{StaticResource SoftButton}" Content="Copy" MinWidth="90" Margin="0,0,10,6" Click="StComputedCopy_Click"/>
                                                                <Button Style="{StaticResource SoftButton}" Content="Export TXT" MinWidth="110" Margin="0,0,10,6" Click="StComputedExportTxt_Click"/>
                                                                <Button Style="{StaticResource SoftButton}" Content="Export CSV" MinWidth="110" Margin="0,0,10,6" Click="StComputedExportCsv_Click"/>
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding SignificanceKind}" Value="Good">
                                                            <Setter TargetName="CSigChip" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                            <Setter TargetName="CSigText" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Details view (readable monospace: dark text on light background) -->
                                        <Border x:Name="StComputedDetailsCard" Style="{StaticResource CardBorder}" Padding="22" Margin="0,16,0,0" Visibility="Collapsed">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Result details" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock x:Name="StComputedDetailsTitle" FontSize="12.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}" Content="Hide" MinWidth="80" VerticalAlignment="Top" Click="StComputedHideDetails_Click"/>
                                                </Grid>
                                                <Border Background="#FFFFFF" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Margin="0,12,0,0">
                                                    <ScrollViewer MaxHeight="460" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="14">
                                                        <TextBlock x:Name="StComputedDetailsText" FontFamily="Consolas" FontSize="12.5" Foreground="#111111" TextWrapping="Wrap"/>
                                                    </ScrollViewer>
                                                </Border>
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Style="{StaticResource SoftButton}" Content="Copy" MinWidth="90" Margin="0,0,10,0" Click="StComputedDetailsCopy_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                    <!-- ============ END COMPUTED RESULTS ============ -->

                                </StackPanel>

                                <!-- RESULTS (Phase 4A — descriptive results overview) -->
                                <Border x:Name="TabResults" Style="{StaticResource CardBorder}" Padding="30" Visibility="Collapsed" VerticalAlignment="Top">
                                    <StackPanel MaxWidth="820">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                                <Path Data="{StaticResource IconDecks}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Results" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Descriptive results generated by deterministic calculations" Style="{StaticResource Caption}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Empty state -->
                                        <StackPanel x:Name="ResEmptyState" Margin="0,22,0,0">
                                            <TextBlock Text="No descriptive statistics have been generated yet. Go to Statistics to run analysis."
                                                       Foreground="{StaticResource MutedBrush}" FontSize="14" TextWrapping="Wrap"/>
                                            <Button Style="{StaticResource PremiumButton}" Content="Go to Statistics" MinWidth="160" HorizontalAlignment="Left" Margin="0,16,0,0" Click="ResBackToStats_Click"/>
                                        </StackPanel>

                                        <!-- Latest analysis -->
                                        <StackPanel x:Name="ResContent" Visibility="Collapsed" Margin="0,20,0,0">
                                            <Border x:Name="ResStaleBanner" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="14,12" Margin="0,0,0,14" Visibility="Collapsed">
                                                <TextBlock Text="Dataset or extraction sheet changed. Rerun descriptive statistics to update results."
                                                           Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Border>
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Latest descriptive analysis" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                    <TextBlock x:Name="ResGeneratedText" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Border x:Name="ResStatusChip" Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource SuccessSoftBrush}" CornerRadius="14" Padding="11,5">
                                                    <TextBlock x:Name="ResStatusChipText" Text="Current" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                                </Border>
                                            </Grid>
                                            <ItemsControl x:Name="ResSummaryList" Margin="0,14,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,7">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Style="{StaticResource PremiumButton}" Content="View Descriptive Tables" MinWidth="190" Margin="0,0,10,6" Click="ResViewTables_Click"/>
                                                <Button Style="{StaticResource SoftButton}" Content="Copy Results" MinWidth="130" Margin="0,0,10,6" Click="StCopyAll_Click"/>
                                                <Button Style="{StaticResource SoftButton}" Content="Export Tables" MinWidth="130" Margin="0,0,10,6" Click="StExportCsv_Click"/>
                                                <Button Style="{StaticResource GhostButton}" Content="Back to Statistics" MinWidth="150" Margin="0,0,10,6" Click="ResBackToStats_Click"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- MANUSCRIPT -->
                                <Border x:Name="TabManuscript" Style="{StaticResource CardBorder}" Padding="30" Visibility="Collapsed" VerticalAlignment="Top">
                                    <StackPanel MaxWidth="760">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                                                <Path Data="{StaticResource IconBook}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Manuscript" Style="{StaticResource SectionHeader}"/>
                                                <TextBlock Text="Coming in the next phase" Style="{StaticResource Caption}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Text="Manuscript writer will draft sections from real project data, real results, and user-provided references."
                                                   Foreground="{StaticResource MutedBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,18,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- NOTES -->
                                <Border x:Name="TabNotes" Style="{StaticResource CardBorder}" Padding="26" Visibility="Collapsed" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Notes" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Keep private notes, references, or reminders for this project." Style="{StaticResource Caption}" Margin="0,4,0,14"/>
                                        <TextBox x:Name="DashNotesBox" Style="{StaticResource EditorTextBox}" MinHeight="240"
                                                 local:Watermark.Text="Write notes for this project…"/>
                                        <Button Content="Save Notes" Style="{StaticResource PremiumButton}" Width="150" HorizontalAlignment="Left" Margin="0,14,0,0" Click="SaveDashNotes_Click"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </ScrollViewer>

                        <!-- ============================================ -->
                        <!-- EDIT PROJECT DETAILS overlay (Phase 2E)       -->
                        <!-- ============================================ -->
                        <Grid x:Name="EditProjectOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="50">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="660" MaxHeight="640"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Edit Project Details" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Update the basics for this research project. Your recommendations and proposal are kept."
                                                   Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,20,0">
                                        <StackPanel Margin="0,6,0,8">
                                            <Border x:Name="EpRecsWarning" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="14,11" Margin="0,0,0,14" Visibility="Collapsed">
                                                <TextBlock Text="This project already has AI recommendations. Editing details does not delete them, but you may want to regenerate recommendations afterwards so the plan stays aligned."
                                                           Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                            </Border>

                                            <TextBlock Text="Project title / idea *" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="EpTitleBox" local:Watermark.Text="e.g. Prevalence of anemia among first-year medical students"/>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Specialty" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="EpSpecialtyBox" local:Watermark.Text="e.g. Internal Medicine"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Study type" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="EpStudyTypeCombo">
                                                        <ComboBoxItem Content="Cross-sectional"/>
                                                        <ComboBoxItem Content="Case-control"/>
                                                        <ComboBoxItem Content="Cohort"/>
                                                        <ComboBoxItem Content="Retrospective"/>
                                                        <ComboBoxItem Content="Systematic review"/>
                                                        <ComboBoxItem Content="Meta-analysis"/>
                                                        <ComboBoxItem Content="Case report"/>
                                                        <ComboBoxItem Content="Not sure"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Research aim" Style="{StaticResource FieldLabel}" Margin="0,16,0,7"/>
                                            <TextBox x:Name="EpAimBox" Style="{StaticResource EditorTextBox}" MinHeight="64"
                                                     local:Watermark.Text="What question is this project trying to answer?"/>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Population" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="EpPopulationBox" local:Watermark.Text="e.g. Adults aged 18–45"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Setting" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="EpSettingBox" local:Watermark.Text="e.g. Teaching hospital, outpatient clinic"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Time period" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="EpTimePeriodBox" local:Watermark.Text="e.g. Jan–Jun 2026"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Available data" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="EpDataCombo">
                                                        <ComboBoxItem Content="Google Form"/>
                                                        <ComboBoxItem Content="Pasted questions"/>
                                                        <ComboBoxItem Content="Excel/CSV"/>
                                                        <ComboBoxItem Content="Manual entry"/>
                                                        <ComboBoxItem Content="No data yet"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Desired outputs" Style="{StaticResource FieldLabel}" Margin="0,16,0,9"/>
                                            <WrapPanel>
                                                <CheckBox x:Name="EpOutProposal" Content="Proposal" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutIntroduction" Content="Introduction" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutMethods" Content="Methods" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutExtraction" Content="Data Extraction Sheet" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutStatistics" Content="Statistics" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutManuscript" Content="Manuscript" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutAbstract" Content="Abstract" Margin="0,0,22,10"/>
                                                <CheckBox x:Name="EpOutTables" Content="Tables" Margin="0,0,22,10"/>
                                            </WrapPanel>

                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}" Margin="0,10,0,7"/>
                                            <TextBox x:Name="EpNotesBox" Style="{StaticResource EditorTextBox}" MinHeight="64"
                                                     local:Watermark.Text="Optional notes, references, or reminders"/>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Border Grid.Row="2" Background="{StaticResource SoftCardBrush}" CornerRadius="0,0,14,14"
                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock x:Name="EpValidationText" Grid.Column="0" Foreground="{StaticResource DangerBrush}"
                                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"
                                                       Margin="0,0,14,0" Visibility="Collapsed"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Cancel" Style="{StaticResource GhostButton}" Width="110" Click="CancelEditProject_Click"/>
                                                <Button Content="Save Changes" Style="{StaticResource PremiumButton}" Width="150" Margin="0" Click="SaveEditProject_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- IMPORT EXISTING PROPOSAL overlay (Phase 2F)   -->
                        <!-- ============================================ -->
                        <Grid x:Name="ImportProposalOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="50">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="680" MaxHeight="640"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Import Existing Proposal" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Upload or paste an existing proposal and let Research AI extract the project details, research plan, variables, analyses, and proposal sections."
                                                   Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,20,0">
                                        <StackPanel Margin="0,6,0,8">
                                            <TextBlock Text="Paste proposal text" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="ImportPasteBox" Style="{StaticResource EditorTextBox}" MinHeight="200" MaxHeight="260"
                                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                                     local:Watermark.Text="Paste the full text of your existing proposal here…"/>

                                            <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,16,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="…or upload a file" Foreground="{StaticResource TextBrush}" FontSize="13.5" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Supported: .txt, .md, .docx (simple documents). The text is read into the box above." Style="{StaticResource Caption}" Margin="0,3,0,10" TextWrapping="Wrap"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Choose File" Style="{StaticResource SoftButton}" Click="ChooseProposalFile_Click"/>
                                                        <TextBlock x:Name="ImportFileNameText" Text="No file chosen" Foreground="{StaticResource MutedBrush}" FontSize="12.5" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Image and scanned-PDF extraction will require OCR/vision support in a later update. For now, please paste the text or use a .txt, .md, or .docx file."
                                                               Foreground="{StaticResource SoftMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#FFF7ED" BorderBrush="#F5C98A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,16,0,0">
                                                <TextBlock Text="Research AI reads only what is in your proposal. It does not invent methods, results, p-values, or references. Anything missing is flagged for you to review."
                                                           Foreground="#9A5B12" FontSize="12.5" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Border Grid.Row="2" Background="{StaticResource SoftCardBrush}" CornerRadius="0,0,14,14"
                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="ImportValidationText" Foreground="{StaticResource DangerBrush}"
                                                           FontWeight="SemiBold" FontSize="13" TextWrapping="Wrap" Visibility="Collapsed"/>
                                                <WrapPanel x:Name="ImportValidationAiActions" Visibility="Collapsed" Margin="0,8,0,0">
                                                    <Button Content="Open Research AI Settings" Style="{StaticResource GhostButton}" Margin="0,0,10,0" Click="OpenResearchAiSettings_Click"/>
                                                    <Button Content="Open details" Style="{StaticResource GhostButton}" Click="ShowAiDiagnostics_Click"/>
                                                </WrapPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Cancel" Style="{StaticResource GhostButton}" Width="110" Click="CancelImportProposal_Click"/>
                                                <Button x:Name="AnalyzeProposalBtn" Style="{StaticResource PremiumButton}" Margin="0" Click="AnalyzeProposal_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconGenerate}" Fill="White" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Analyze with Research AI" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- REVIEW EXTRACTED DETAILS overlay (Phase 2G)   -->
                        <!-- ============================================ -->
                        <Grid x:Name="ReviewExtractionOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="55">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="760" MaxHeight="680"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Review Extracted Proposal Details" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Check what Research AI found. Edit the key fields if needed, then apply. Nothing is applied to your project until you click Apply."
                                                   Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,20,0">
                                        <StackPanel Margin="0,6,0,8">

                                            <!-- Project Details (editable) -->
                                            <TextBlock Text="Project Details" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,4,0,8"/>
                                            <TextBlock Text="Title" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="RvTitle" Style="{StaticResource EditorTextBox}"/>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Specialty" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="RvSpecialty" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Study design" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="RvStudyDesign" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,2,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Population" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="RvPopulation" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Setting" Style="{StaticResource RpFieldLabel}"/>
                                                    <TextBox x:Name="RvSetting" Style="{StaticResource EditorTextBox}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Time period" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="RvTimePeriod" Style="{StaticResource EditorTextBox}"/>

                                            <!-- Research Question & Objectives -->
                                            <TextBlock Text="Research Question &amp; Objectives" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <TextBlock Text="Research question" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="RvResearchQuestion" Style="{StaticResource EditorTextBox}" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Aim" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="RvAim" Style="{StaticResource EditorTextBox}" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock Text="Primary objective" Style="{StaticResource RpFieldLabel}"/>
                                            <TextBox x:Name="RvPrimaryObjective" Style="{StaticResource EditorTextBox}" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="RvSecondaryObjectives" Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"/>

                                            <!-- Study Design & Methods -->
                                            <TextBlock Text="Study Design &amp; Methods" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <TextBlock x:Name="RvMethods" Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap"/>

                                            <!-- Criteria -->
                                            <TextBlock Text="Criteria" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <TextBlock x:Name="RvCriteria" Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap"/>

                                            <!-- Variables & Analyses -->
                                            <TextBlock Text="Variables &amp; Analyses" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <TextBlock x:Name="RvVariablesAnalyses" Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap"/>

                                            <!-- Ethics & Limitations -->
                                            <TextBlock Text="Ethics &amp; Limitations" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <TextBlock x:Name="RvEthicsLimitations" Foreground="{StaticResource TextBrush}" FontSize="13" TextWrapping="Wrap"/>

                                            <!-- Proposal Sections -->
                                            <TextBlock Text="Proposal Sections" Foreground="{StaticResource PrimaryBrush}" FontSize="13" FontWeight="Bold" Margin="0,18,0,8"/>
                                            <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="14">
                                                <TextBlock x:Name="RvProposalSections" Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- Missing / Weak Sections -->
                                            <Border x:Name="RvMissingCard" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="14" Margin="0,16,0,0" Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="Missing / Weak Sections" Foreground="{StaticResource WarningBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="RvMissing" Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Warnings / Confidence -->
                                            <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="10" Padding="14" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Warnings / Confidence" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" FontWeight="Bold" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="RvConfidence" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="RvWarnings" Foreground="{StaticResource PrimaryBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Border Grid.Row="2" Background="{StaticResource SoftCardBrush}" CornerRadius="0,0,14,14"
                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="Re-analyze" Style="{StaticResource GhostButton}" Click="ReanalyzeExtraction_Click"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="Cancel" Style="{StaticResource GhostButton}" Width="110" Click="CancelReview_Click"/>
                                                <Button Content="Apply Extracted Details" Style="{StaticResource PremiumButton}" Margin="0" Click="ApplyExtraction_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- Generic Research Lab confirm overlay          -->
                        <!-- ============================================ -->
                        <Grid x:Name="RlConfirmOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="60">
                            <Border Style="{StaticResource CardBorder}" Padding="28" Width="460"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel>
                                    <TextBlock x:Name="RlConfirmTitle" Text="Confirm" Style="{StaticResource SectionHeader}"/>
                                    <TextBlock x:Name="RlConfirmMessage" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                                        <Button x:Name="RlConfirmCancelBtn" Style="{StaticResource GhostButton}" MinWidth="110" Click="RlConfirmCancel_Click">
                                            <TextBlock x:Name="RlConfirmCancelText" Text="Cancel"/>
                                        </Button>
                                        <Button x:Name="RlConfirmOkBtn" Style="{StaticResource PremiumButton}" MinWidth="150" Margin="0" Click="RlConfirmOk_Click">
                                            <TextBlock x:Name="RlConfirmOkText" Text="Confirm"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- PASTE QUESTIONS overlay (Phase 3)            -->
                        <!-- ============================================ -->
                        <Grid x:Name="PasteQuestionsOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="52">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="620" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Paste questionnaire / form questions" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="One question per line. Research AI will turn each into a draft variable for you to review." Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Margin="26,6,26,4">
                                        <TextBox x:Name="DxQuestionsBox" Style="{StaticResource EditorTextBox}" MinHeight="220" AcceptsReturn="True" TextWrapping="Wrap"
                                                 local:Watermark.Text="e.g.&#x0a;How many hours do you sleep per night?&#x0a;Do you have chronic headaches? (Yes/No)&#x0a;What is your academic year?"/>
                                        <TextBlock x:Name="DxQuestionsValidation" Foreground="{StaticResource DangerBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="26,10,26,22">
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="110" Click="CancelPasteQuestions_Click"/>
                                        <Button x:Name="DxExtractQuestionsBtn" Style="{StaticResource PremiumButton}" Content="Extract Variables from Questions" MinWidth="240" Margin="0" Click="ExtractVariablesFromQuestions_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- GOOGLE FORM LINK overlay (Phase 3)           -->
                        <!-- ============================================ -->
                        <Grid x:Name="GoogleFormOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="52">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="580" MaxHeight="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Google Form link" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="Paste your form link. We save it with the project and can try to read visible questions from a public form." Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Margin="26,6,26,4">
                                        <TextBlock Text="Form URL" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="DxFormUrlBox" local:Watermark.Text="https://docs.google.com/forms/…  or  https://forms.gle/…"/>
                                        <Border Background="{StaticResource InfoSoftBrush}" CornerRadius="9" Padding="13,11" Margin="0,14,0,0">
                                            <TextBlock Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap"
                                                       Text="No Google sign-in is required or used. Private forms cannot be read — if a form can't be read automatically, paste its questions instead. Nothing is submitted to the form."/>
                                        </Border>
                                        <TextBlock x:Name="DxFormMessage" FontSize="12.5" TextWrapping="Wrap" Margin="0,12,0,0" Visibility="Collapsed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="26,12,26,22">
                                        <Button Style="{StaticResource GhostButton}" Content="Close" MinWidth="90" Click="CancelGoogleForm_Click"/>
                                        <Button x:Name="DxReadFormBtn" Style="{StaticResource SoftButton}" Content="Try to read questions" MinWidth="170" Click="TryReadForm_Click"/>
                                        <Button Style="{StaticResource PremiumButton}" Content="Save link" MinWidth="120" Margin="0" Click="SaveFormLink_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- VARIABLE EDIT overlay (Phase 3)              -->
                        <!-- ============================================ -->
                        <Grid x:Name="VariableEditOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="57">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="640" MaxHeight="660" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock x:Name="VeHeaderText" Text="Edit variable" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock Text="All fields for this variable. Use a short machine name (letters, numbers, underscores)." Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,0,20,0">
                                        <StackPanel Margin="0,6,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Variable name" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="VeName" local:Watermark.Text="e.g. sleep_hours"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Question label" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="VeLabel" local:Watermark.Text="Human wording / question"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Type" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="VeType"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Measurement level" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="VeLevel"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Role" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="VeRole"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Coding" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="VeCoding" local:Watermark.Text="e.g. 0 = No, 1 = Yes"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Value labels" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="VeValueLabels" local:Watermark.Text="Category → meaning"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Missing value rule" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox x:Name="VeMissing" local:Watermark.Text="e.g. blank = missing"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Source" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox x:Name="VeSource"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Notes" Style="{StaticResource FieldLabel}" Margin="0,14,0,0"/>
                                            <TextBox x:Name="VeNotes" Style="{StaticResource EditorTextBox}" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap"/>
                                            <CheckBox x:Name="VeRequired" Content="Required field" Margin="0,14,0,0"/>
                                            <Border x:Name="VeValidationBorder" Background="{StaticResource DangerSoftBrush}" CornerRadius="8" Padding="12,10" Margin="0,14,0,0" Visibility="Collapsed">
                                                <TextBlock x:Name="VeValidation" Foreground="{StaticResource DangerBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="26,10,26,22">
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="110" Click="CancelEditVariable_Click"/>
                                        <Button Style="{StaticResource PremiumButton}" Content="Save variable" MinWidth="150" Margin="0" Click="SaveEditVariable_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- REVIEW AI EXTRACTION SHEET overlay (Phase 3) -->
                        <!-- ============================================ -->
                        <Grid x:Name="ExtractionReviewOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="56">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="880" MaxHeight="680" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="Review AI Extraction Sheet" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock x:Name="DxReviewSubtitle" Text="Review the suggested variables before applying. Nothing changes until you choose an action below."
                                                   Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <Border x:Name="DxReviewConfidenceCard" Background="{StaticResource SoftCardBrush}" CornerRadius="9" Padding="13,10" Margin="0,12,0,0" Visibility="Collapsed">
                                            <TextBlock x:Name="DxReviewConfidence" FontSize="12.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,4,20,0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock x:Name="DxReviewCountText" Text="Suggested variables" FontWeight="Bold" FontSize="13.5" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Edit any cell, or remove a row, before applying." FontSize="12" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                            </Grid>
                                            <DataGrid x:Name="DxReviewGrid" Style="{StaticResource ResearchDataGrid}" MaxHeight="320" AutoGenerateColumns="False"
                                                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Variable name" Binding="{Binding VariableName}" Width="130">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Label" Binding="{Binding QuestionLabel}" Width="160"/>
                                                    <DataGridComboBoxColumn Header="Type" SelectedItemBinding="{Binding VariableType}" ItemsSource="{x:Static local:ResearchVariableOptions.VariableTypes}" Width="100"/>
                                                    <DataGridComboBoxColumn Header="Level" SelectedItemBinding="{Binding MeasurementLevel}" ItemsSource="{x:Static local:ResearchVariableOptions.MeasurementLevels}" Width="95"/>
                                                    <DataGridComboBoxColumn Header="Role" SelectedItemBinding="{Binding Role}" ItemsSource="{x:Static local:ResearchVariableOptions.Roles}" Width="105"/>
                                                    <DataGridTextColumn Header="Coding" Binding="{Binding Coding}" Width="120"/>
                                                    <DataGridComboBoxColumn Header="Source" SelectedItemBinding="{Binding Source}" ItemsSource="{x:Static local:ResearchVariableOptions.Sources}" Width="120"/>
                                                    <DataGridCheckBoxColumn Header="Req." Binding="{Binding IsRequired}" Width="46"/>
                                                    <DataGridTemplateColumn Header="" Width="44" CanUserSort="False">
                                                        <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                                            <Button Style="{StaticResource GridActionButton}" Click="ReviewDeleteRow_Click" ToolTip="Remove this suggestion">
                                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource DangerBrush}" Width="13" Height="13" Stretch="Uniform"/>
                                                            </Button>
                                                        </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <StackPanel x:Name="DxReviewMissingSection" Visibility="Collapsed" Margin="0,16,0,0">
                                                <TextBlock Text="Concepts to double-check (not yet represented)" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource WarningBrush}" Margin="0,0,0,6"/>
                                                <ItemsControl x:Name="DxReviewMissingList">
                                                    <ItemsControl.ItemTemplate><DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    </DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <StackPanel x:Name="DxReviewExtraSection" Visibility="Collapsed" Margin="0,12,0,0">
                                                <TextBlock Text="CSV columns not mapped to a planned variable" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource InfoBrush}" Margin="0,0,0,6"/>
                                                <ItemsControl x:Name="DxReviewExtraList">
                                                    <ItemsControl.ItemTemplate><DataTemplate>
                                                        <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    </DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,14,26,18">
                                        <StackPanel>
                                            <Border x:Name="DxReviewValidation" Background="{StaticResource DangerSoftBrush}" CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Visibility="Collapsed">
                                                <TextBlock x:Name="DxReviewValidationText" Foreground="{StaticResource DangerBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                            </Border>
                                            <WrapPanel HorizontalAlignment="Right">
                                                <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="110" Click="ExtractionReviewCancel_Click"/>
                                                <Button x:Name="DxReviewApplyBtn" Style="{StaticResource PremiumButton}" MinWidth="200" Margin="0" Click="ExtractionReviewApply_Click">
                                                    <TextBlock x:Name="DxReviewApplyText" Text="Apply to Sheet"/>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- REVIEW AI CONFLICT FIXES overlay (Phase 3 final) -->
                        <!-- One proposal per conflict: accept / edit / delete each before applying. -->
                        <!-- ============================================ -->
                        <Grid x:Name="ExtractionFixReviewOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="56">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="760" MaxHeight="640" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Grid Margin="26,24,26,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Review Research AI Conflict Cleanup" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock x:Name="DxFixSourceLabel" Text="Local cleanup suggestions" Visibility="Collapsed"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,3,0,0"/>
                                            <TextBlock Text="Grouped by how Research AI triaged each conflict. Tick the ones to apply, edit any value, or remove proposals you disagree with. Nothing changes until you confirm."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="520"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Padding="12,6">
                                            <TextBlock x:Name="DxFixCountText" Text="0 proposals" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,4,20,0">
                                        <StackPanel>
                                            <StackPanel x:Name="DxFixWarningsSection" Visibility="Collapsed" Margin="0,0,0,10">
                                                <ItemsControl x:Name="DxFixWarningsList">
                                                    <ItemsControl.ItemTemplate><DataTemplate>
                                                        <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="8" Padding="12,9" Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding}" Foreground="{StaticResource WarningBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </DataTemplate></ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <ItemsControl x:Name="DxFixProposalsList">
                                                <ItemsControl.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="12,7" Margin="0,4,0,8">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource TextBrush}"/>
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ItemsControl.GroupStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox IsChecked="{Binding Accepted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          IsEnabled="{Binding IsApplicable}" VerticalAlignment="Top" Margin="0,2,12,0"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding ConflictTitle}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                        <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="7" Padding="8,3" Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding ActionDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                                        </Border>
                                                                        <Border x:Name="ConfChip" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="8,3" Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding TargetDisplay}" FontSize="11.5" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Explanation}" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                                    <StackPanel x:Name="ValueRow" Orientation="Horizontal" Margin="0,7,0,0">
                                                                        <TextBlock Text="Value:" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBox Text="{Binding ProposedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Width="300" Height="30" MinHeight="30" FontSize="12" VerticalContentAlignment="Center"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Remove" MinWidth="76" Height="30" MinHeight="30"
                                                                        FontSize="11.5" VerticalAlignment="Top" Foreground="{StaticResource DangerBrush}" Click="ConflictFixRemove_Click"/>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding Confidence}" Value="high">
                                                                <Setter TargetName="ConfChip" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsApplicable}" Value="False">
                                                                <Setter TargetName="ValueRow" Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,12,26,16">
                                        <StackPanel>
                                            <WrapPanel Margin="0,0,0,8">
                                                <Button Style="{StaticResource SoftButton}" Content="Accept all high-confidence safe fixes" MinWidth="230" Margin="0,0,10,6" Click="ConflictFixAcceptHighSafe_Click"/>
                                                <Button Style="{StaticResource SoftButton}" Content="Accept all safe ignores" MinWidth="170" Margin="0,0,10,6" Click="ConflictFixAcceptIgnores_Click"/>
                                            </WrapPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="100" Margin="0,0,10,0" Click="ExtractionFixCancel_Click"/>
                                                <Button Style="{StaticResource PremiumButton}" Content="Apply selected" MinWidth="150" Margin="0" Click="ExtractionFixApply_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- AI CLEANUP SUMMARY modal (before applying)   -->
                        <!-- Sits above the review overlay (Z57) so Go Back returns to it. -->
                        <!-- ============================================ -->
                        <Grid x:Name="AiCleanupSummaryOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="59">
                            <Border Style="{StaticResource CardBorder}" Padding="28" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Research AI cleanup summary" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                    <TextBlock x:Name="AiCleanupSummaryText" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,14,0,0"/>
                                    <TextBlock Text="Nothing will change until you confirm." Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <WrapPanel HorizontalAlignment="Right" Margin="0,20,0,0">
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="100" Margin="0,0,10,6" Click="AiCleanupCancel_Click"/>
                                        <Button Style="{StaticResource SoftButton}" Content="Go Back" MinWidth="110" Margin="0,0,10,6" Click="AiCleanupGoBack_Click"/>
                                        <Button Style="{StaticResource PremiumButton}" Content="Confirm and Apply" MinWidth="170" Margin="0,0,0,6" Click="AiCleanupConfirm_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- MAGIC FIX review overlay (Phase 4A)          -->
                        <!-- Deterministic local sheet-repair suggestions. -->
                        <!-- ============================================ -->
                        <Grid x:Name="MagicFixReviewOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="62">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="820" MaxHeight="660" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Grid Margin="26,24,26,8">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Review Magic Fix Suggestions" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Magic Fix found possible repairs for variable types and coding. Review them before applying. Nothing changes until you confirm. Your CSV data is never modified."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="560"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource PrimarySoftBrush}" CornerRadius="16" Padding="12,6">
                                            <TextBlock x:Name="MagicFixCountText" Text="0 suggestions" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                        </Border>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,4,20,0">
                                        <ItemsControl x:Name="MagicFixList">
                                            <ItemsControl.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{StaticResource SoftCardBrush}" CornerRadius="7" Padding="12,7" Margin="0,4,0,8">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource TextBrush}"/>
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource MutedBrush}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ItemsControl.GroupStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <CheckBox IsChecked="{Binding Accepted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding IsApplicable}" VerticalAlignment="Top" Margin="0,2,12,0"/>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding VariableName}" FontWeight="Bold" FontSize="12.5" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                    <TextBlock Text="{Binding CurrentTypeDisplay}" FontSize="11.5" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="  →  " FontSize="11.5" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                                                    <Border Background="{StaticResource PrimarySoftBrush}" CornerRadius="7" Padding="8,3" Margin="0,0,6,0">
                                                                        <TextBlock Text="{Binding ProposedTypeDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                                                    </Border>
                                                                    <Border x:Name="MfConfChip" Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="8,3">
                                                                        <TextBlock Text="{Binding ConfidenceDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Explanation}" FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                                                <TextBlock Margin="0,5,0,0" FontSize="11.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap">
                                                                    <Run Text="Observed values: " FontWeight="SemiBold"/><Run Text="{Binding ObservedPreview}"/>
                                                                </TextBlock>
                                                                <StackPanel x:Name="MfEditRow" Orientation="Horizontal" Margin="0,8,0,0">
                                                                    <StackPanel Margin="0,0,12,0">
                                                                        <TextBlock Text="Proposed type" FontSize="10.5" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                                                        <ComboBox x:Name="MfTypeBox" Width="140" FontSize="12"
                                                                                  ItemsSource="{x:Static local:ResearchVariableOptions.VariableTypes}"
                                                                                  SelectedItem="{Binding ProposedType, Mode=TwoWay}"/>
                                                                    </StackPanel>
                                                                    <StackPanel x:Name="MfCodingCol">
                                                                        <TextBlock Text="Value labels / coding" FontSize="10.5" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                                                        <TextBox Text="{Binding ProposedCoding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Width="360" Height="30" MinHeight="30" FontSize="12" VerticalContentAlignment="Center"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <Button Grid.Column="2" Style="{StaticResource GhostButton}" Content="Remove" MinWidth="76" Height="30" MinHeight="30"
                                                                    FontSize="11.5" VerticalAlignment="Top" Foreground="{StaticResource DangerBrush}" Click="MagicFixRemove_Click"/>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Confidence}" Value="High">
                                                            <Setter TargetName="MfConfChip" Property="Background" Value="{StaticResource SuccessSoftBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ChangesCoding}" Value="False">
                                                            <Setter TargetName="MfCodingCol" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsApplicable}" Value="False">
                                                            <Setter TargetName="MfEditRow" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,12,26,16">
                                        <StackPanel>
                                            <WrapPanel Margin="0,0,0,8">
                                                <Button Style="{StaticResource SoftButton}" Content="Accept all high-confidence repairs" MinWidth="240" Margin="0,0,10,6" Click="MagicFixAcceptHigh_Click"/>
                                            </WrapPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="100" Margin="0,0,10,0" Click="MagicFixCancel_Click"/>
                                                <Button Style="{StaticResource PremiumButton}" Content="Apply selected" MinWidth="150" Margin="0" Click="MagicFixApply_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- MAGIC FIX confirm summary (Phase 4A) -->
                        <Grid x:Name="MagicFixSummaryOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="63">
                            <Border Style="{StaticResource CardBorder}" Padding="28" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="Apply Magic Fix suggestions?" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                    <TextBlock x:Name="MagicFixSummaryText" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,14,0,0"/>
                                    <TextBlock Text="Only the extraction sheet is updated. Your CSV data is never changed. Nothing will change until you confirm."
                                               Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    <WrapPanel HorizontalAlignment="Right" Margin="0,20,0,0">
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="100" Margin="0,0,10,6" Click="MagicFixSummaryCancel_Click"/>
                                        <Button Style="{StaticResource SoftButton}" Content="Go Back" MinWidth="110" Margin="0,0,10,6" Click="MagicFixSummaryGoBack_Click"/>
                                        <Button Style="{StaticResource PremiumButton}" Content="Confirm and Apply" MinWidth="170" Margin="0,0,0,6" Click="MagicFixConfirm_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- CSV SUMMARY overlay (Phase 3)                -->
                        <!-- ============================================ -->
                        <Grid x:Name="CsvSummaryOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="55">
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="700" MaxHeight="620" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="26,24,26,8">
                                        <TextBlock Text="CSV Summary" Style="{StaticResource SectionHeader}"/>
                                        <TextBlock x:Name="CsvSummaryTitle" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource TextBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="CsvSummarySub" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,6,20,0">
                                        <ItemsControl x:Name="CsvSummaryList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="8" Padding="14,10" Margin="0,0,0,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                                <TextBlock FontSize="12" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0">
                                                                    <Run Text="{Binding InferredType, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding UniqueCount, Mode=OneWay}"/><Run Text=" unique · "/><Run Text="{Binding MissingPercent, Mode=OneWay}"/><Run Text="% missing"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" FontSize="11.5" Foreground="{StaticResource SoftMutedBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="240">
                                                                <Run Text="e.g. "/><Run Text="{Binding SampleValuesDisplay, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="26,12,26,22">
                                        <Button Style="{StaticResource PremiumButton}" Content="Close" MinWidth="120" Margin="0" Click="CloseCsvSummary_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- RESOLVE CONFLICTS overlay (Phase 3)          -->
                        <!-- ============================================ -->
                        <Grid x:Name="ConflictOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="54">
                            <Grid.Resources>
                                <Style x:Key="ConflictBtn" TargetType="Button" BasedOn="{StaticResource SoftButton}">
                                    <Setter Property="Height" Value="32"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Padding" Value="13,0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Margin" Value="0,0,8,6"/>
                                </Style>
                                <Style x:Key="ConflictGhostBtn" TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Setter Property="Height" Value="32"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Padding" Value="13,0"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Margin" Value="0,0,8,6"/>
                                </Style>
                            </Grid.Resources>
                            <Border Style="{StaticResource CardBorder}" Padding="0" Width="780" MaxHeight="680" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <Grid Margin="26,24,26,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Resolve Sheet–Sample Conflicts" Style="{StaticResource SectionHeader}"/>
                                            <TextBlock Text="Differences between your extraction sheet, sample data, and plan. Fix each one manually, or let Research AI propose fixes — nothing is applied without your review."
                                                       Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" VerticalAlignment="Top" Background="{StaticResource WarningSoftBrush}" CornerRadius="16" Padding="12,6">
                                            <TextBlock x:Name="DxConflictCountText" Text="0 conflicts" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                                        </Border>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="26,4,20,0">
                                        <StackPanel>
                                            <Border x:Name="DxConflictEmpty" Background="{StaticResource SuccessSoftBrush}" CornerRadius="10" Padding="16,14" Visibility="Collapsed" Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconCheck}" Fill="{StaticResource SuccessBrush}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                    <TextBlock x:Name="DxConflictEmptyText" Text="No conflicts detected." Foreground="{StaticResource SuccessBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="600"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Fix with Research AI timeout/failure — stays inside the modal; clears nothing -->
                                            <Border x:Name="DxConflictAiTimeout" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Padding="16,14" Visibility="Collapsed" Margin="0,0,0,10">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconWarn}" Fill="{StaticResource WarningBrush}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                        <TextBlock x:Name="DxConflictAiTimeoutText" Text="Research AI timed out while proposing conflict fixes. You can still resolve conflicts manually." Foreground="{StaticResource WarningBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="600"/>
                                                    </StackPanel>
                                                    <WrapPanel Margin="0,10,0,0">
                                                        <Button Style="{StaticResource ConflictBtn}" Content="Retry AI Fix" Click="ConflictAiRetry_Click"/>
                                                        <Button Style="{StaticResource ConflictBtn}" Content="Continue Manually" Click="ConflictAiContinueManually_Click"/>
                                                        <Button Style="{StaticResource ConflictBtn}" Content="Open Research AI Settings" Click="OpenResearchAiSettings_Click"/>
                                                        <Button Style="{StaticResource ConflictGhostBtn}" Content="Open details" Click="ShowAiDiagnostics_Click"/>
                                                        <Button Style="{StaticResource ConflictGhostBtn}" Content="Close" Click="ConflictCloseAfterTimeout_Click"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl x:Name="ConflictList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource SoftCardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,6">
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border CornerRadius="8" Padding="9,3" Margin="0,0,6,0">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Severity}" Value="Error"><Setter Property="Background" Value="{StaticResource DangerSoftBrush}"/></DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Severity}" Value="Suggestion"><Setter Property="Background" Value="{StaticResource InfoSoftBrush}"/></DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="{Binding Severity}" FontSize="10.5" FontWeight="Bold">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Severity}" Value="Error"><Setter Property="Foreground" Value="{StaticResource DangerBrush}"/></DataTrigger>
                                                                                            <DataTrigger Binding="{Binding Severity}" Value="Suggestion"><Setter Property="Foreground" Value="{StaticResource InfoBrush}"/></DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Border>
                                                                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="9,3">
                                                                            <TextBlock Text="{Binding Source}" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <!-- Staged status chip -->
                                                                    <Border Grid.Column="1" CornerRadius="8" Padding="9,3">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource SoftCardBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Resolved"><Setter Property="Background" Value="{StaticResource SuccessSoftBrush}"/></DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Ignored"><Setter Property="Background" Value="{StaticResource SoftCardBrush}"/></DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Status}" Value="Needs review"><Setter Property="Background" Value="{StaticResource WarningSoftBrush}"/></DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding Status}" FontSize="10.5" FontWeight="Bold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Status}" Value="Resolved"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Status}" Value="Needs review"><Setter Property="Foreground" Value="{StaticResource WarningBrush}"/></DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding Detail}" FontSize="12.5" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,3,0,10"/>
                                                                <WrapPanel>
                                                                    <Button Style="{StaticResource ConflictBtn}" Content="Add to sheet" Visibility="{Binding AddVis}" Click="ConflictAdd_Click"/>
                                                                    <ComboBox Width="180" Height="32" MinHeight="32" FontSize="12" Margin="0,0,8,6" Visibility="{Binding MatchVis}"
                                                                              ItemsSource="{Binding MatchCandidates}" SelectedItem="{Binding SelectedMatch}"/>
                                                                    <Button Style="{StaticResource ConflictBtn}" Content="Match with existing" Visibility="{Binding MatchVis}" Click="ConflictMatch_Click"/>
                                                                    <Button Style="{StaticResource ConflictBtn}" Content="Rename variable" Visibility="{Binding RenameVis}" Click="ConflictEdit_Click"/>
                                                                    <Button Style="{StaticResource ConflictBtn}" Content="Edit manually" Visibility="{Binding EditVis}" Click="ConflictEdit_Click"/>
                                                                    <Button Style="{StaticResource ConflictGhostBtn}" Foreground="{StaticResource DangerBrush}" Content="Delete from sheet" Visibility="{Binding DeleteVis}" Click="ConflictDelete_Click"/>
                                                                    <Button Style="{StaticResource ConflictGhostBtn}" Content="Mark resolved" Click="ConflictMarkResolved_Click"/>
                                                                    <Button Style="{StaticResource ConflictGhostBtn}" Content="Ignore" Click="ConflictIgnore_Click"/>
                                                                </WrapPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="26,14,26,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Resolve manually and Save. Fix with Research AI is optional." FontSize="12" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                                            <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="100" Margin="0,0,10,0" Click="ConflictCancel_Click"/>
                                                <Button Style="{StaticResource SoftButton}" MinWidth="170" Margin="0,0,10,0" Click="ConflictFixAi_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{StaticResource IconGenerate}" Fill="{StaticResource PrimaryBrush}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Fix with Research AI" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource PremiumButton}" Content="Save and Close" MinWidth="160" Margin="0" Click="ConflictSaveClose_Click"/>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- ============================================ -->
                        <!-- AI DELAY / CANCEL overlay (Phase 3 polish)   -->
                        <!-- ============================================ -->
                        <Grid x:Name="AiDelayOverlay" Grid.RowSpan="3" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="58">
                            <Border Style="{StaticResource CardBorder}" Padding="28" Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="42" Height="42" Background="{StaticResource PrimarySoftBrush}" CornerRadius="10" Margin="0,0,13,0" VerticalAlignment="Center">
                                            <Path Data="{StaticResource IconGenerate}" Fill="{StaticResource PrimaryBrush}" Width="19" Height="19" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="AiDelayTitle" Text="Research AI" Style="{StaticResource SectionHeader}" FontSize="16"/>
                                            <TextBlock Text="Research AI will start in 5 seconds. You can cancel now." Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" MaxWidth="330" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="9" Padding="13,10" Margin="0,16,0,0">
                                        <TextBlock x:Name="AiDelayCountText" Text="Starting in 5 seconds…" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                        <Button Style="{StaticResource GhostButton}" Content="Cancel" MinWidth="110" Click="AiDelayCancel_Click"/>
                                        <Button Style="{StaticResource PremiumButton}" Content="Start Now" MinWidth="130" Margin="0" Click="AiDelayStartNow_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>

                </Grid>

                <!-- STATUS BAR -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}" Padding="16,0">
                    <TextBlock x:Name="StatusText" Text="Ready." Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>

        <!-- LOADING OVERLAY -->
        <Grid x:Name="LoadingOverlay" Background="#88000000" Visibility="Collapsed">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="20"
                    Padding="34"
                    Width="430"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">

                    <Border Width="118" Height="118" Background="{StaticResource PrimarySoftBrush}" CornerRadius="28" Margin="0,0,0,18">
                        <Grid>
                            <Image x:Name="LoadingGifImage"
                                   Source="/Assets/Animations/Loading.gif"
                                   Width="92"
                                   Height="92"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            <Path Data="{StaticResource IconBolt}"
                                  Fill="{StaticResource PrimaryBrush}"
                                  Width="34" Height="34"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0.18"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="LoadingMessageText"
                               Text="Working..."
                               Foreground="{StaticResource TextBrush}"
                               FontSize="23"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Please wait while the app processes your request."
                               Foreground="{StaticResource MutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- RESEARCH AI — long-running work overlay      -->
        <!-- Blocking, stays in front of the user (no background mode). -->
        <!-- Shows a simple step checklist + elapsed timer + Cancel only. -->
        <!-- ============================================ -->
        <Grid x:Name="AiWorkingOverlay" Background="#88000000" Visibility="Collapsed" Panel.ZIndex="150">
            <Border Background="{StaticResource CardBrush}" CornerRadius="20" Padding="34" Width="460"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{StaticResource PrimarySoftBrush}" CornerRadius="12" Margin="0,0,14,0">
                            <Path Data="{StaticResource IconBolt}" Fill="{StaticResource PrimaryBrush}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="AiWorkTitleText" Text="Research AI is working" Style="{StaticResource SectionHeader}" FontSize="17"/>
                            <TextBlock x:Name="AiWorkActionText" Text="Working…" Foreground="{StaticResource MutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Elapsed timer -->
                    <Border Background="{StaticResource SoftCardBrush}" CornerRadius="10" Padding="14,10" Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Elapsed time" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AiWorkElapsedText" Grid.Column="1" Text="0:00" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Step checklist: pending ○ / current ● / done ✓ -->
                    <ItemsControl x:Name="AiWorkStepsList" Margin="4,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,3">
                                    <TextBlock x:Name="StepGlyph" Text="{Binding Glyph}" Width="24" FontSize="13.5" FontWeight="Bold"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StepLabel" Text="{Binding Label}" FontSize="13"
                                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding State}" Value="Done">
                                        <Setter TargetName="StepGlyph" Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Setter TargetName="StepLabel" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding State}" Value="Current">
                                        <Setter TargetName="StepGlyph" Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter TargetName="StepLabel" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        <Setter TargetName="StepLabel" Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="This may take several minutes for complex research tasks. Please keep the app open."
                               Foreground="{StaticResource MutedBrush}" FontSize="12.5" TextWrapping="Wrap" Margin="0,14,0,0"/>

                    <Border x:Name="AiWorkStillWorkingNote" Background="{StaticResource WarningSoftBrush}" CornerRadius="9" Padding="12,10" Margin="0,10,0,0" Visibility="Collapsed">
                        <TextBlock Text="Still working — complex research tasks can take several minutes. Your content is safe; no need to restart." Foreground="{StaticResource WarningBrush}" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Style="{StaticResource PremiumButton}" Background="{StaticResource DangerBrush}" Content="Cancel" MinWidth="110" Margin="0" Click="AiWorkCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- RESEARCH AI — failure/timeout-after-max-duration overlay -->
        <!-- Generic and reusable: Retry re-invokes whatever action failed via a -->
        <!-- stored delegate (smart retry — never resends raw/huge data since -->
        <!-- each action's retry re-runs the SAME compact-input pipeline). -->
        <!-- ============================================ -->
        <Grid x:Name="AiFailureOverlay" Background="#8A1B1B2A" Visibility="Collapsed" Panel.ZIndex="151">
            <Border Style="{StaticResource CardBorder}" Padding="28" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42" Height="42" Background="{StaticResource WarningSoftBrush}" CornerRadius="10" Margin="0,0,13,0">
                            <Path Data="{StaticResource IconWarn}" Fill="{StaticResource WarningBrush}" Width="19" Height="19" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Research AI" Style="{StaticResource SectionHeader}" FontSize="16" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="AiFailureMessageText" Foreground="{StaticResource TextBrush}" FontSize="13.5" TextWrapping="Wrap" Margin="0,14,0,0"/>
                    <WrapPanel Margin="0,18,0,0">
                        <Button Style="{StaticResource PremiumButton}" Content="Retry" MinWidth="100" Margin="0,0,10,6" Click="AiFailureRetry_Click"/>
                        <Button Style="{StaticResource SoftButton}" Content="Continue Manually" MinWidth="150" Margin="0,0,10,6" Click="AiFailureContinueManually_Click"/>
                        <Button Style="{StaticResource SoftButton}" Content="Open Research AI Settings" MinWidth="180" Margin="0,0,10,6" Click="AiFailureOpenSettings_Click"/>
                        <Button Style="{StaticResource GhostButton}" Content="Open details" MinWidth="100" Margin="0,0,10,6" Click="ShowAiDiagnostics_Click"/>
                        <Button Style="{StaticResource GhostButton}" Content="Close" MinWidth="90" Margin="0,0,0,6" Click="AiFailureContinueManually_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- TOAST HOST -->
        <StackPanel x:Name="ToastHost"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,22,22,0"
                    Panel.ZIndex="200"/>

    </Grid>
</Window>

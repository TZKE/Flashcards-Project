<Window x:Class="AIFlashcardMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Flashcard Maker"
        Width="1380"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource BgBrush}">

        <!-- LOGIN / SIGNUP -->
        <Grid x:Name="AuthGrid" Margin="34">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.44*"/>
                <ColumnDefinition Width="0.56*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="20" VerticalAlignment="Center">
                <TextBlock Text="AI Flashcard Maker"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Generate, organize, review, and export medical flashcards in one premium Windows app."
                           FontSize="16"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"
                           Margin="0,16,30,28"/>

                <TextBlock Text="✓ Z.ai automatic flashcard generation" Foreground="{StaticResource GreenBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,6"/>
                <TextBlock Text="✓ Decks, study mode, and Anki export" Foreground="{StaticResource GreenBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,6"/>
                <TextBlock Text="✓ Local demo activation system" Foreground="{StaticResource GreenBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,6"/>

                <Border Background="#1F2937" CornerRadius="14" Padding="18" Margin="0,34,40,0">
                    <TextBlock Foreground="{StaticResource YellowBrush}" FontFamily="Consolas" FontSize="13"
                               Text="Demo activation codes:&#x0a;FLASH-MONTH-2026&#x0a;FLASH-YEAR-2026&#x0a;FLASH-LIFE-2026"/>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    CornerRadius="22"
                    Padding="28"
                    Margin="30,60"
                    Effect="{DynamicResource {x:Static SystemParameters.DropShadowKey}}">
                <TabControl>
                    <TabItem Header="Login">
                        <StackPanel Margin="22">
                            <TextBlock Text="Welcome back" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,30"/>

                            <TextBlock Text="Email" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                            <TextBox x:Name="LoginEmailBox" Height="44" Margin="0,8,0,18"/>

                            <TextBlock Text="Password" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="LoginPasswordBox" Height="44" Margin="0,8,0,24"/>

                            <Button Content="Login" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="Login_Click" Height="46"/>

                            <TextBlock Text="New users must create an account with an activation code."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       Margin="0,24,0,0"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Create Account">
                        <StackPanel Margin="22">
                            <TextBlock Text="Create account" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,26"/>

                            <TextBlock Text="Email" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                            <TextBox x:Name="SignupEmailBox" Height="44" Margin="0,8,0,14"/>

                            <TextBlock Text="Password" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                            <PasswordBox x:Name="SignupPasswordBox" Height="44" Margin="0,8,0,14"/>

                            <TextBlock Text="Activation Code" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                            <TextBox x:Name="SignupCodeBox" Height="44" Margin="0,8,0,22"/>

                            <Button Content="Create Account" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="Signup_Click" Height="46"/>

                            <TextBlock Foreground="{StaticResource YellowBrush}" FontFamily="Consolas" FontSize="12" Margin="0,22,0,0"
                                       Text="FLASH-MONTH-2026&#x0a;FLASH-YEAR-2026&#x0a;FLASH-LIFE-2026"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- MAIN APP -->
        <Grid x:Name="AppGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" Padding="22,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="520"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="42" Height="42" Background="{StaticResource BlueBrush}" CornerRadius="12" Margin="0,0,14,0">
                            <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="AI Flashcard Maker" FontSize="25" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="UserSummaryText"
                               Grid.Column="1"
                               Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="13"/>

                    <Button Grid.Column="2" Content="Logout" Style="{StaticResource PremiumButton}" Background="#374151" Click="Logout_Click" Margin="14,0,0,0"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0F172A" Padding="16">
                    <StackPanel>
                        <Button Content="🏠  Dashboard" Style="{StaticResource NavButton}" Click="Dashboard_Click"/>
                        <Button Content="✨  Generate" Style="{StaticResource NavButton}" Click="GeneratePage_Click"/>
                        <Button Content="📥  Import JSON" Style="{StaticResource NavButton}" Click="ImportPage_Click"/>
                        <Button Content="🗂️  My Deck" Style="{StaticResource NavButton}" Click="DeckPage_Click"/>
                        <Button Content="🎯  Study Mode" Style="{StaticResource NavButton}" Click="StudyPage_Click"/>
                        <Button Content="✏️  Preview / Edit" Style="{StaticResource NavButton}" Click="PreviewPage_Click"/>
                        <Button Content="📤  Export" Style="{StaticResource NavButton}" Click="ExportPage_Click"/>
                        <Button Content="🔑  AI Settings" Style="{StaticResource NavButton}" Click="SettingsPage_Click"/>
                        <Button Content="👤  Account" Style="{StaticResource NavButton}" Click="AccountPage_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Margin="22" x:Name="ContentRoot">

                    <!-- DASHBOARD -->
                    <Grid x:Name="PageDashboard">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="150"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Dashboard" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Your local study workspace. Generate cards, review them, then export when needed."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,12,0,18">
                            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="20" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Total Cards" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                                    <TextBlock x:Name="StatsTotalCards" Text="0" Foreground="{StaticResource TextBrush}" FontSize="34" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="20" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Due Today" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                                    <TextBlock x:Name="StatsDueCards" Text="0" Foreground="{StaticResource GreenBrush}" FontSize="34" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Studied Today" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                                    <TextBlock x:Name="StatsStudiedToday" Text="0" Foreground="{StaticResource BlueBrush}" FontSize="34" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="22">
                            <StackPanel>
                                <TextBlock Text="Recommended next step" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Paste your notes in Generate, then click Generate with Z.ai. Cards will be saved locally and can be studied inside this app."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,10,0,20"/>
                                <Button Content="Go to Generate" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="GeneratePage_Click" Width="170"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- GENERATE -->
                    <Grid x:Name="PageGenerate" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="70"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Generate Flashcards" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Paste notes and generate flashcards automatically using Z.ai GLM-4.7-FlashX."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Mode" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ModeCombo" Width="190" Margin="0,0,18,0"/>

                            <TextBlock Text="Difficulty" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="DifficultyCombo" Width="150" Margin="0,0,18,0"/>

                            <TextBlock Text="Answer" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="AnswerLengthCombo" Width="150" Margin="0,0,18,0"/>

                            <TextBlock Text="Count" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CountCombo" Width="100" Margin="0,0,18,0"/>

                            <TextBlock Text="Language" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="LanguageCombo" Width="230"/>
                        </WrapPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.64*"/>
                                <ColumnDefinition Width="0.36*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="58"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Source Material" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBox x:Name="SourceBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Generate with Z.ai" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="GenerateAutomatic_Click" Width="170"/>
                                        <Button Content="Create Manual Prompt" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="CreatePrompt_Click" Width="180"/>
                                        <Button Content="Clear" Style="{StaticResource PremiumButton}" Background="#374151" Click="ClearSource_Click" Width="90"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="58"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Manual Prompt Backup" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBox x:Name="PromptBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                    <Button Grid.Row="2" Content="Copy Prompt" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="CopyPrompt_Click" Width="140" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- IMPORT -->
                    <Grid x:Name="PageImport" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Import AI JSON" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Paste JSON generated by any AI. Automatic Z.ai generation skips this step."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.66*"/>
                                <ColumnDefinition Width="0.34*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18" Margin="0,0,14,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="58"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Paste AI JSON Answer" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBox x:Name="ImportBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Import Cards" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="ImportCards_Click" Width="140"/>
                                        <Button Content="Clear" Style="{StaticResource PremiumButton}" Background="#374151" Click="ClearImport_Click" Width="90"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Imported Cards" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <ListBox x:Name="ImportedList" Grid.Row="1" Background="{StaticResource InputBrush}" Foreground="{StaticResource TextBrush}" SelectionChanged="ImportedList_SelectionChanged"/>
                                    <TextBlock x:Name="ImportSummaryText" Grid.Row="2" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- DECK -->
                    <Grid x:Name="PageDeck" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="My Deck" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="A local deck of generated/imported cards. Full multi-deck support comes next."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="58"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="DeckSummaryText" Text="0 cards" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                <ListBox x:Name="DeckList" Grid.Row="1" Background="{StaticResource InputBrush}" Foreground="{StaticResource TextBrush}" SelectionChanged="DeckList_SelectionChanged"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="Study Now" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="StudyPage_Click" Width="130"/>
                                    <Button Content="Preview Selected" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="PreviewSelected_Click" Width="160"/>
                                    <Button Content="Delete Selected" Style="{StaticResource PremiumButton}" Background="{StaticResource RedBrush}" Click="DeleteSelected_Click" Width="150"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- STUDY -->
                    <Grid x:Name="PageStudy" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Study Mode" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Review cards inside the app. Use Again / Hard / Good / Easy to schedule basic spaced repetition."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="24" Padding="34" Margin="60,20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="46"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="80"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="StudyProgressText" Text="No cards" Foreground="{StaticResource MutedBrush}" FontSize="15"/>

                                <Border Grid.Row="1" Background="{StaticResource InputBrush}" CornerRadius="18" Padding="32">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="StudyFrontText" Text="No card selected." TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}" FontSize="28" FontWeight="SemiBold" TextAlignment="Center"/>

                                        <Border x:Name="StudyAnswerPanel" Visibility="Collapsed" Background="#111827" CornerRadius="14" Padding="22" Margin="0,34,0,0">
                                            <TextBlock x:Name="StudyBackText" TextWrapping="Wrap" Foreground="{StaticResource GreenBrush}" FontSize="22" TextAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="StudyHintText" Grid.Row="2" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,14,0,0" TextAlignment="Center"/>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="Show Answer" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="ShowAnswer_Click" Width="150"/>
                                    <Button Content="Again" Style="{StaticResource PremiumButton}" Background="{StaticResource RedBrush}" Click="Again_Click" Width="100"/>
                                    <Button Content="Hard" Style="{StaticResource PremiumButton}" Background="#F59E0B" Click="Hard_Click" Width="100"/>
                                    <Button Content="Good" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="Good_Click" Width="100"/>
                                    <Button Content="Easy" Style="{StaticResource PremiumButton}" Background="#22C55E" Click="Easy_Click" Width="100"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- PREVIEW -->
                    <Grid x:Name="PagePreview" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Preview / Edit" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Edit front, back, and tags. Changes are saved when you move cards or click Save."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="44"/>
                                    <RowDefinition Height="0.42*"/>
                                    <RowDefinition Height="0.42*"/>
                                    <RowDefinition Height="72"/>
                                    <RowDefinition Height="76"/>
                                    <RowDefinition Height="60"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="CardCounterText" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>

                                <GroupBox Grid.Row="1" Header="Front" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10">
                                    <TextBox x:Name="FrontBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                </GroupBox>

                                <GroupBox Grid.Row="2" Header="Back" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10">
                                    <TextBox x:Name="BackBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                </GroupBox>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Previous" Style="{StaticResource PremiumButton}" Background="#374151" Click="Previous_Click" Width="110"/>
                                    <Button Content="Next" Style="{StaticResource PremiumButton}" Background="#374151" Click="Next_Click" Width="90"/>
                                    <Button Content="Save" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="SaveCard_Click" Width="90"/>
                                    <Button Content="Delete" Style="{StaticResource PremiumButton}" Background="{StaticResource RedBrush}" Click="DeleteCard_Click" Width="100"/>
                                    <Button Content="Copy Current" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="CopyCurrent_Click" Width="150"/>
                                </StackPanel>

                                <GroupBox Grid.Row="4" Header="Tags" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10">
                                    <TextBox x:Name="TagsBox"/>
                                </GroupBox>

                                <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Copy All For Anki" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="CopyAll_Click" Width="180"/>
                                    <Button Content="Export .txt" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="ExportTxt_Click" Width="120"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- EXPORT -->
                    <Grid x:Name="PageExport" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="70"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Export" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Export as tab-separated fields: Front, Back, Tags."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="18">
                            <TextBox x:Name="ExportPreviewBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Refresh Preview" Style="{StaticResource PremiumButton}" Background="#374151" Click="RefreshExport_Click" Width="150"/>
                            <Button Content="Copy All For Anki" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="CopyAll_Click" Width="180"/>
                            <Button Content="Export .txt" Style="{StaticResource PremiumButton}" Background="{StaticResource BlueBrush}" Click="ExportTxt_Click" Width="120"/>
                        </StackPanel>
                    </Grid>

                    <!-- SETTINGS -->
                    <Grid x:Name="PageSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="AI Settings" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Your Z.ai key is saved locally on this computer. Later, the backend will hide this key from users."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="28">
                            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                                <TextBlock Text="Z.ai API" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                                <TextBlock Text="API Key" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="ApiKeyBox" Height="44" Margin="0,8,0,18"/>

                                <TextBlock Text="Model" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                <TextBox x:Name="ModelBox" Height="44" Margin="0,8,0,18"/>

                                <TextBlock Text="Base URL" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                <TextBox x:Name="BaseUrlBox" Height="44" Margin="0,8,0,22"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save Settings" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="SaveSettings_Click" Width="150"/>
                                    <Button Content="Clear Key" Style="{StaticResource PremiumButton}" Background="{StaticResource RedBrush}" Click="ClearKey_Click" Width="120"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ACCOUNT -->
                    <Grid x:Name="PageAccount" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="82"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Account" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Local demo account and activation. Real subscription support will use backend later."
                                       Foreground="{StaticResource MutedBrush}" FontSize="14"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="18" Padding="28">
                            <StackPanel MaxWidth="850" HorizontalAlignment="Left">
                                <TextBlock Text="Subscription Details" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>

                                <TextBlock x:Name="AccountEmailText" Foreground="{StaticResource TextBrush}" FontSize="16" Margin="0,8"/>
                                <TextBlock x:Name="AccountPlanText" Foreground="{StaticResource GreenBrush}" FontSize="16" Margin="0,8"/>
                                <TextBlock x:Name="AccountExpiryText" Foreground="{StaticResource MutedBrush}" FontSize="16" Margin="0,8,0,30"/>

                                <TextBlock Text="Apply new activation code" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"/>
                                <TextBox x:Name="ApplyCodeBox" Height="44" Margin="0,8,0,18"/>

                                <Button Content="Apply Code" Style="{StaticResource PremiumButton}" Background="{StaticResource GreenBrush}" Click="ApplyCode_Click" Width="130"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource PanelBrush}">
                <TextBlock x:Name="StatusText" Text="Ready." Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="16,0"/>
            </Border>
        </Grid>
    </Grid>
</Window>
